@{
    ViewData["Title"] = "Bán Hàng Tại Quầy (POS)";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h2 class="fw-bolder text-dark mb-0"><i class="fa fa-cash-register text-success me-2"></i>Bán Hàng Tại Quầy (POS)</h2>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success fw-bold shadow-sm rounded-3 fs-5 py-3 border-0"><i class="fa fa-check-circle me-2"></i> @TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger fw-bold shadow-sm rounded-3 border-0"><i class="fa fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]</div>
    }

    <form asp-action="POS" method="post">
        <div class="row">
            <div class="col-md-5 mb-4">
                <div class="card shadow-sm border-0 rounded-4 h-100">
                    <div class="card-header bg-white border-bottom py-3">
                        <h5 class="mb-0 fw-bold text-dark"><i class="fa fa-user-tag text-primary me-2"></i>Thông tin Giao dịch</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">CỬA HÀNG ĐANG GIAO DỊCH <span class="text-danger">*</span></label>
                            <select name="branchId" class="form-select shadow-sm border-0 bg-light" asp-items="ViewBag.Branches" required>
                                <option value="">-- Chọn Cửa hàng / Chi nhánh --</option>
                            </select>
                        </div>
                        <hr class="my-4" />
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">TÊN KHÁCH HÀNG</label>
                            <input type="text" name="customerName" class="form-control shadow-sm border-0 bg-light" placeholder="Nhập tên khách (hoặc để trống nếu là khách lẻ)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">SỐ ĐIỆN THOẠI</label>
                            <input type="text" name="phone" class="form-control shadow-sm border-0 bg-light" placeholder="Nhập số điện thoại để lưu bảo hành..." />
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-7 mb-4">
                <div class="card shadow-sm border-0 rounded-4 border-top border-success border-5 h-100">
                    <div class="card-header bg-white border-bottom py-3">
                        <h5 class="mb-0 fw-bold text-dark"><i class="fa fa-barcode text-success me-2"></i>Quét IMEI Sản Phẩm <span class="text-danger">*</span></h5>
                    </div>
                    <div class="card-body p-4">
                        <p class="text-muted small mb-2">
                            <i class="fa fa-lightbulb text-warning me-1"></i>
                            <strong>Mẹo thu ngân:</strong> Cầm súng quét mã vạch và bắn liên tục vào hộp các sản phẩm khách mua. Hệ thống sẽ tự động tính tiền và xuất kho.
                        </p>
                        <textarea name="scannedImeis" class="form-control shadow-sm bg-light border-0 font-monospace fs-4 text-success fw-bold p-3" rows="6" placeholder="Nhập mã Imei" required></textarea>
                        
                        <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-success btn-lg rounded-pill px-5 fw-bold shadow-lg">
                                <i class="fa fa-print me-2"></i> THANH TOÁN & IN BILL
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>