@{
    ViewData["Title"] = "Nhập Kho IMEI";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Dùng chung layout có thanh menu bên trái
}

<div class="container-fluid px-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bolder text-dark mb-0"><i class="fa fa-barcode text-primary me-2"></i>Nhập Kho Thiết Bị (IMEI)</h2>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success fw-bold shadow-sm rounded-3 border-0"><i class="fa fa-check-circle me-2"></i> @TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger fw-bold shadow-sm rounded-3 border-0"><i class="fa fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]</div>
    }

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-white border-bottom py-3">
            <h5 class="mb-0 fw-bold text-dark"><i class="fa fa-box-open me-2 text-warning"></i>Thông tin lô hàng</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="ImportImei" method="post">
                <div class="row mb-4">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label class="form-label fw-bold text-muted small">1. NHẬP VÀO CHI NHÁNH <span class="text-danger">*</span></label>
                        <select name="branchId" class="form-select form-select-lg shadow-sm border-0 bg-light" asp-items="ViewBag.Branches" required>
                            <option value="">-- Click để chọn chi nhánh kho --</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small">2. LOẠI ĐIỆN THOẠI <span class="text-danger">*</span></label>
                        <select name="productId" class="form-select form-select-lg shadow-sm border-0 bg-light" asp-items="ViewBag.Products" required>
                            <option value="">-- Click để chọn tên dòng máy --</option>
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold text-muted small">3. DANH SÁCH MÃ IMEI <span class="text-danger">*</span></label>
                    <p class="text-muted small mb-2"><i class="fa fa-lightbulb text-warning me-1"></i><strong>Mẹo:</strong> Đặt con trỏ chuột vào ô bên dưới và dùng súng bắn mã vạch quét liên tục các hộp điện thoại. Bạn cũng có thể copy một cột IMEI từ Excel và Paste thẳng vào đây.</p>
                    <textarea name="imeiList" class="form-control shadow-sm bg-light border-0 font-monospace fs-5" rows="8" placeholder="Ví dụ:&#10;351234567890123&#10;351234567890124" required></textarea>
                </div>

                <div class="d-flex justify-content-end border-top pt-4">
                    <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow-sm">
                        <i class="fa fa-save me-2"></i> Xác Nhận Lưu Kho
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>