@model IEnumerable<PhoneStore.Models.Order>
@{
    ViewData["Title"] = "Xử lý Đơn hàng Online";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Sử dụng chung giao diện Admin
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bolder text-dark mb-0"><i class="fa fa-clipboard-list text-info me-2"></i>Nghiệp vụ Xử lý Đơn hàng</h2>
    <div class="badge bg-info bg-opacity-10 text-info px-4 py-2 fs-6 rounded-pill border border-info border-opacity-25 shadow-sm">
        Tổng số: <span class="fw-bolder">@Model.Count() đơn</span>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success fw-bold shadow-sm rounded-3 alert-dismissible fade show border-0" role="alert">
        <i class="fa fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0 rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">KHÁCH HÀNG</th>
                        <th>CHI TIẾT MÁY</th>
                        <th>TỔNG TIỀN</th>
                        <th>TRẠNG THÁI</th>
                        <th class="pe-4 text-center">XỬ LÝ</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="5" class="text-center py-5 text-muted fw-bold">Hiện tại không có đơn hàng nào cần xử lý.</td></tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-primary fs-6">@item.CustomerName</div>
                                    <div class="text-muted small"><i class="fa fa-phone me-1"></i>@item.Phone</div>
                                    <div class="text-muted small"><i class="fa fa-map-marker-alt me-1"></i>@item.Address</div>
                                    <div class="text-muted small mt-1"><i class="fa fa-clock me-1"></i>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                                </td>
                                
                                <td>
                                    <ul class="list-unstyled mb-0 small">
                                        @foreach (var detail in item.OrderDetails)
                                        {
                                            <li>
                                                <i class="fa fa-caret-right text-muted me-1"></i>@detail.Product?.Name
                                                <span class="fw-bold text-danger ms-1">x @(detail.Quantity)</span>
                                            </li>
                                        }
                                    </ul>
                                </td>
                                
                                <td class="text-danger fw-bold fs-6">
                                    @item.TotalAmount.ToString("N0")<small class="text-muted ms-1">đ</small>
                                </td>
                                
                                <td>
                                    @{
                                        var badgeClass = item.Status switch { "Pending" => "bg-warning text-dark", "Success" => "bg-success", "Cancelled" => "bg-danger", _ => "bg-secondary" };
                                        var statusText = item.Status switch { "Pending" => "Chờ duyệt", "Success" => "Hoàn thành", "Cancelled" => "Đã hủy", _ => item.Status };
                                    }
                                    <span class="badge @badgeClass px-3 py-2 shadow-sm rounded-pill fw-bold">@statusText</span>
                                </td>
                                
                                <td class="pe-4">
                                    @if (item.Status == "Pending")
                                    {
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-action="FulfillOrder" asp-route-id="@item.Id" class="btn btn-warning btn-sm fw-bold px-3 shadow-sm rounded-pill text-dark border border-warning">
                                                <i class="fa fa-box-open me-1"></i> Xuất kho
                                            </a>
                                            
                                            <form asp-action="UpdateOrderStatus" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn HỦY đơn hàng của khách hàng @item.CustomerName?');">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="status" value="Cancelled" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm fw-bold px-3 shadow-sm rounded-pill">
                                                    Hủy
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else if (item.Status == "Success")
                                    {
                                        <div class="text-success fw-bold text-center small"><i class="fa fa-check-circle me-1"></i>Đã giao & KH bảo hành</div>
                                    }
                                    else if (item.Status == "Cancelled")
                                    {
                                        <div class="text-danger fw-bold text-center small"><i class="fa fa-times-circle me-1"></i>Khách/NV đã hủy</div>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>