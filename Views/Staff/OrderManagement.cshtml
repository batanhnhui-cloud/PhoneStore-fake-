@model IEnumerable<PhoneStore.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="fw-bold text-primary mb-4"><i class="fa fa-list-alt me-2"></i>Danh sách đơn hàng</h2>

<div class="card shadow border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Thông tin khách</th>
                    <th>Chi tiết máy đã mua</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th class="text-end pe-4">Xử lý</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold">@item.CustomerName</div>
                            <div class="small text-muted"><i class="fa fa-phone me-1"></i>@item.Phone</div>
                            <div class="small text-muted"><i class="fa fa-map-marker-alt me-1"></i>@item.Address</div>
                        </td>
                        <td>
                            <ul class="list-unstyled mb-0 small">
                                @foreach (var detail in item.OrderDetails)
                                {
                                    <li>- @detail.Product?.Name <span class="badge bg-light text-dark">x@detail.Quantity</span></li>
                                }
                            </ul>
                        </td>
                        <td class="text-danger fw-bold">@item.TotalAmount.ToString("N0") đ</td>
                        <td>
                            <span class="badge @(item.Status == "Success" ? "bg-success" : item.Status == "Cancelled" ? "bg-danger" : "bg-warning text-dark")">
                                @item.Status
                            </span>
                        </td>
                        <td class="text-end pe-4">
                            <form asp-action="UpdateOrderStatus" method="post" class="d-inline-flex">
                                <input type="hidden" name="orderId" value="@item.Id" />
                                <select name="status" class="form-select form-select-sm me-1">
                                    <option value="Pending" selected="@(item.Status == "Pending")">Chờ</option>
                                    <option value="Success" selected="@(item.Status == "Success")">Xong</option>
                                    <option value="Cancelled" selected="@(item.Status == "Cancelled")">Hủy</option>
                                </select>
                                <button type="submit" class="btn btn-sm btn-primary">Lưu</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>