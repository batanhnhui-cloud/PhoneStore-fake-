@model IEnumerable<PhoneStore.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary"><i class="fa fa-shopping-cart me-2"></i>Quản lý Đơn hàng</h2>
    <span class="badge bg-secondary p-2">Tổng số: @Model.Count() đơn</span>
</div>

<div class="card shadow border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Mã Đơn</th>
                    <th>Khách hàng</th>
                    <th>Ngày đặt</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">Chưa có đơn hàng nào.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-primary">#@item.Id</td>
                            <td>
                                <div class="fw-bold">@item.CustomerName</div>
                                <small class="text-muted">@item.PhoneNumber</small>
                            </td>
                            <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-danger fw-bold">@item.TotalAmount.ToString("N0") đ</td>
                            <td>
                                @{
                                    var badgeClass = item.Status switch
                                    {
                                        "Pending" => "bg-warning text-dark",
                                        "Success" => "bg-success",
                                        "Cancelled" => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass">@item.Status</span>
                            </td>
                            <td class="text-end pe-4">
                                <form asp-action="UpdateOrderStatus" method="post" class="d-inline-flex align-items-center">
                                    <input type="hidden" name="orderId" value="@item.Id" />
                                    <select name="status" class="form-select form-select-sm me-2" style="width: 130px;">
                                        <option value="Pending" selected="@(item.Status == "Pending")">Chờ xử lý</option>
                                        <option value="Success" selected="@(item.Status == "Success")">Hoàn thành</option>
                                        <option value="Cancelled" selected="@(item.Status == "Cancelled")">Hủy đơn</option>
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-primary">
                                        <i class="fa fa-save"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>