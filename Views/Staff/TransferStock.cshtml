@model IEnumerable<PhoneStore.Models.ImeiTransfer>
@{
    ViewData["Title"] = "Điều chuyển Kho (Luân chuyển)";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h2 class="fw-bolder text-dark mb-0"><i class="fa fa-truck-moving text-primary me-2"></i>Nghiệp vụ Điều chuyển Kho</h2>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success fw-bold shadow-sm rounded-3 border-0"><i class="fa fa-check-circle me-2"></i> @TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger fw-bold shadow-sm rounded-3 border-0"><i class="fa fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]</div>
    }

    <div class="row">
        <div class="col-lg-5 mb-4">
            <div class="card shadow-sm border-0 rounded-4 h-100 border-top border-primary border-5">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="fa fa-file-export text-primary me-2"></i>Lập phiếu xuất kho</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="CreateTransfer" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">TỪ CHI NHÁNH (Kho xuất) <span class="text-danger">*</span></label>
                            <select name="fromBranchId" class="form-select shadow-sm border-0 bg-light" asp-items="ViewBag.Branches" required>
                                <option value="">-- Chọn Kho đang có máy --</option>
                            </select>
                        </div>
                        <div class="mb-3 text-center">
                            <i class="fa fa-arrow-down text-muted fs-4"></i>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">ĐẾN CHI NHÁNH (Kho nhận) <span class="text-danger">*</span></label>
                            <select name="toBranchId" class="form-select shadow-sm border-0 bg-light" asp-items="ViewBag.Branches" required>
                                <option value="">-- Chọn Kho đích đến --</option>
                            </select>
                        </div>
                        <div class="mb-4 mt-4">
                            <label class="form-label fw-bold text-muted small">QUÉT MÃ IMEI ĐIỀU CHUYỂN <span class="text-danger">*</span></label>
                            <textarea name="scannedImeis" class="form-control shadow-sm bg-light border-0 font-monospace fs-5 p-3" rows="4" placeholder="Quét các mã IMEI cần chuyển vào đây..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 btn-lg rounded-pill fw-bold shadow-sm">
                            <i class="fa fa-truck me-2"></i> Cho xe xuất phát
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-7 mb-4">
            <div class="card shadow-sm border-0 rounded-4 h-100 border-top border-warning border-5">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="fa fa-box-open text-warning me-2"></i>Hàng đang đi trên đường (Chờ nhận)</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Tuyến đường</th>
                                    <th>Thông tin máy</th>
                                    <th class="text-center">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Any())
                                {
                                    <tr><td colspan="3" class="text-center py-5 fw-bold text-muted">Không có lô hàng nào đang luân chuyển.</td></tr>
                                }
                                else
                                {
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="fw-bold text-danger">Từ: @item.FromBranch?.Name</div>
                                                <div class="fw-bold text-success mt-1">Đến: @item.ToBranch?.Name</div>
                                                <div class="text-muted small mt-1"><i class="fa fa-clock me-1"></i>Xuất lúc: @item.TransferDate.ToString("HH:mm dd/MM")</div>
                                            </td>
                                            <td>
                                                <div class="fw-bold text-primary">@item.DeviceImei?.Product?.Name</div>
                                                <div class="font-monospace text-dark bg-light px-2 py-1 rounded d-inline-block mt-1 border">@item.DeviceImei?.Imei</div>
                                            </td>
                                            <td class="text-center pe-4">
                                                <form asp-action="ReceiveTransfer" method="post" onsubmit="return confirm('Xác nhận: Bạn đã cầm máy trên tay và kiểm tra đúng mã IMEI này chưa?');">
                                                    <input type="hidden" name="transferId" value="@item.Id" />
                                                    <button type="submit" class="btn btn-warning btn-sm fw-bold px-3 shadow-sm rounded-pill">
                                                        <i class="fa fa-check-circle me-1"></i> Nhận hàng
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>