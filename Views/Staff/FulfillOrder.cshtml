@model PhoneStore.Models.Order
@{
    ViewData["Title"] = "Xuất kho & Kích hoạt bảo hành";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bolder text-dark mb-0"><i class="fa fa-barcode text-success me-2"></i>Xuất Kho - Đơn hàng #@Model.Id</h2>
        <a asp-action="OrderManagement" class="btn btn-outline-secondary rounded-pill fw-bold px-4"><i class="fa fa-arrow-left me-2"></i>Quay lại</a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger fw-bold shadow-sm rounded-3 border-0"><i class="fa fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]</div>
    }

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="fa fa-receipt text-primary me-2"></i>Chi tiết khách hàng</h5>
                </div>
                <div class="card-body">
                    <p class="mb-2"><span class="text-muted small fw-bold">KHÁCH HÀNG:</span> <br /><span class="fs-5 fw-bolder text-dark">@Model.CustomerName</span></p>
                    <p class="mb-2"><span class="text-muted small fw-bold">ĐIỆN THOẠI:</span> <br /><span class="fw-bold">@Model.Phone</span></p>
                    <p class="mb-2"><span class="text-muted small fw-bold">GIAO ĐẾN:</span> <br />@Model.Address</p>
                    <hr />
                    <p class="mb-0 text-danger fs-4 fw-bolder text-end">Tổng: @Model.TotalAmount.ToString("N0") đ</p>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 border-top border-success border-5">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="fa fa-qrcode text-success me-2"></i>Quét IMEI xuất bán</h5>
                    <p class="text-muted small mb-0 mt-1">Vui lòng quét chính xác mã IMEI của từng sản phẩm để kích hoạt bảo hành điện tử.</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="FulfillOrder" method="post">
                        <input type="hidden" name="orderId" value="@Model.Id" />
                        
                        @foreach (var detail in Model.OrderDetails)
                        {
                            <div class="mb-4 p-3 bg-light rounded-3 border">
                                <h6 class="fw-bolder text-primary mb-3">
                                    <i class="fa fa-mobile-alt me-2"></i>@detail.Product?.Name
                                    <span class="badge bg-danger ms-2">Số lượng: @detail.Quantity</span>
                                </h6>
                                
                                <div class="row">
                                    @for (int i = 0; i < detail.Quantity; i++)
                                    {
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label text-muted small fw-bold">Máy thứ @(i + 1)</label>
                                            <div class="input-group input-group-lg shadow-sm">
                                                <span class="input-group-text bg-white border-end-0"><i class="fa fa-barcode text-muted"></i></span>
                                                <input type="text" name="scannedImeis" class="form-control border-start-0 fw-bold text-success" placeholder="Click & Quét mã..." required autocomplete="off" />
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <div class="d-flex justify-content-end mt-4">
                            <button type="submit" class="btn btn-success btn-lg rounded-pill px-5 fw-bold shadow-sm">
                                <i class="fa fa-check-circle me-2"></i> Xác nhận Xuất kho
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>