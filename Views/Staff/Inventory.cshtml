@model IEnumerable<PhoneStore.Controllers.InventoryStatVM>
@{
    ViewData["Title"] = "Quản lý Tồn kho";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h2 class="fw-bolder text-dark mb-0"><i class="fa fa-boxes text-primary me-2"></i>Dashboard Kho Hàng</h2>
        <div>
            <a asp-action="ImportImei" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm me-2">
                <i class="fa fa-plus me-2"></i>Nhập kho IMEI
            </a>
            <a asp-action="OrderManagement" class="btn btn-outline-dark rounded-pill px-4 fw-bold shadow-sm">
                <i class="fa fa-shopping-cart me-2"></i>Đơn hàng Online
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success fw-bold shadow-sm rounded-3"><i class="fa fa-check-circle me-2"></i> @TempData["SuccessMessage"]</div>
    }

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card bg-primary text-white shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <h6 class="fw-bold opacity-75 mb-3">TỔNG MÁY SẴN SÀNG BÁN</h6>
                    <h1 class="display-4 fw-bolder mb-0">@Model.Sum(m => m.AvailableCount) <span class="fs-5 fw-normal">thiết bị</span></h1>
                </div>
            </div>
        </div>

        <div class="col-md-8 mb-4">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="fa fa-list me-2 text-info"></i>Chi tiết theo dòng máy</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">TÊN CHI NHÁNH</th>
                                <th>TÊN ĐIỆN THOẠI</th>
                                <th class="text-center">SỐ LƯỢNG SẴN SÀNG</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr><td colspan="3" class="text-center py-5 fw-bold text-danger">Kho đang trống. Vui lòng bấm "Nhập kho IMEI" để nhập hàng.</td></tr>
                            }
                            else
                            {
                                @foreach (var item in Model.OrderBy(m => m.BranchName).ThenBy(m => m.ProductName))
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold text-dark"><i class="fa fa-store text-muted me-2"></i>@item.BranchName</td>
                                        <td class="text-primary fw-semibold">@item.ProductName</td>
                                        <td class="text-center">
                                            <span class="badge @(item.AvailableCount < 5 ? "bg-danger" : "bg-success") rounded-pill px-3 py-2 fs-6 shadow-sm">
                                                @item.AvailableCount máy
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>