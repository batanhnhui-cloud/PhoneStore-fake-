@model IEnumerable<PhoneStore.Controllers.InventoryStatVM>
@{
    ViewData["Title"] = "Quản lý Tồn kho";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bolder text-dark mb-0"><i class="fa fa-boxes me-2" style="color: var(--sun-primary);"></i>Dashboard Kho Hàng</h2>
    <div>
        <a asp-action="ImportImei" class="btn btn-sun rounded-pill px-4 fw-bold shadow-sm me-2">
            <i class="fa fa-plus me-2"></i>Nhập kho IMEI
        </a>
        <a asp-action="OrderManagement" class="btn btn-white border rounded-pill px-4 fw-bold shadow-sm text-dark bg-white">
            <i class="fa fa-shopping-cart me-2 text-primary"></i>Đơn hàng Online
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success fw-bold shadow-sm rounded-4 border-0 mb-4"><i class="fa fa-check-circle me-2"></i> @TempData["SuccessMessage"]</div>
}

<div class="row g-4">
    <div class="col-xl-4 col-md-6">
        <div class="card bg-dark text-white h-100 overflow-hidden" style="background: linear-gradient(135deg, var(--sun-dark) 0%, var(--sun-sidebar) 100%);">
            <div class="card-body p-4 position-relative">
                <i class="fa fa-mobile-alt position-absolute opacity-10" style="font-size: 8rem; right: -20px; bottom: -20px;"></i>
                <h6 class="fw-bold opacity-75 mb-3 text-uppercase tracking-wide">TỔNG MÁY SẴN SÀNG BÁN</h6>
                <h1 class="display-3 fw-bolder mb-0" style="color: var(--sun-primary);">@Model.Sum(m => m.AvailableCount) <span class="fs-5 fw-normal text-white">thiết bị</span></h1>
            </div>
        </div>
    </div>

    <div class="col-xl-8 col-md-12">
        <div class="card h-100 border-top border-4" style="border-top-color: var(--sun-primary) !important;">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 fw-bold text-dark"><i class="fa fa-list me-2 text-muted"></i>Chi tiết theo dòng máy</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light text-muted small text-uppercase">
                            <tr>
                                <th class="ps-4 py-3">Chi nhánh</th>
                                <th class="py-3">Tên điện thoại</th>
                                <th class="text-center py-3">Tồn kho</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr><td colspan="3" class="text-center py-5 fw-bold text-danger">Kho đang trống. Vui lòng nhập hàng.</td></tr>
                            }
                            else
                            {
                                @foreach (var item in Model.OrderBy(m => m.BranchName).ThenBy(m => m.ProductName))
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold text-dark"><i class="fa fa-store text-muted me-2 small"></i>@item.BranchName</td>
                                        <td class="text-primary fw-semibold">@item.ProductName</td>
                                        <td class="text-center">
                                            <span class="badge rounded-pill px-3 py-2 fs-6" style="background-color: @(item.AvailableCount < 5 ? "#ef4444" : "#10b981");">
                                                @item.AvailableCount máy
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>