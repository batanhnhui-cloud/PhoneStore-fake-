@model PhoneStore.Models.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-5">
        <div class="card shadow border-0 p-4">
            <h3 class="text-center fw-bold text-success mb-4">TẠO TÀI KHOẢN</h3>
            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Họ và Tên</label>
                    <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên..." />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="Nhập địa chỉ email..." />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Số điện thoại</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="Ví dụ: 0912345678" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Mật khẩu</label>
                    <input asp-for="Password" class="form-control" placeholder="Nhập mật khẩu..." />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Xác nhận mật khẩu</label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu..." />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-success w-100 fw-bold py-2">ĐĂNG KÝ TÀI KHOẢN</button>
            </form>
            <div class="text-center mt-3">
                <span class="text-muted">Đã có tài khoản? </span>
                <a asp-action="Login" class="text-decoration-none fw-bold text-success">Đăng nhập</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}