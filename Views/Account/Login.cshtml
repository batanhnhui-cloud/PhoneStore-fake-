@{
    Layout = null; // Không dùng Layout chung để trang đăng nhập nhìn sạch sẽ hơn
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đăng nhập - PhoneStore Management</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background: #f4f7fc; display: flex; align-items: center; justify-content: center; height: 100vh; }
        .login-card { width: 400px; border: none; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
        .btn-primary { background: #4e73df; border: none; padding: 12px; }
    </style>
</head>
<body>

<div class="card login-card p-4">
    <div class="text-center mb-4">
        <h3 class="fw-bold text-primary">PHONESTORE</h3>
        <p class="text-muted">Đăng nhập để quản lý hệ thống</p>
    </div>

    <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
        <div asp-validation-summary="All" class="text-danger small mb-3"></div>
        
        <div class="mb-3">
            <label class="form-label">Email</label>
            <input name="email" type="email" class="form-control" placeholder="admin@phonestore.com" required />
        </div>
        
        <div class="mb-3">
            <label class="form-label">Mật khẩu</label>
            <input name="password" type="password" class="form-control" required />
        </div>

        <div class="mb-3 form-check">
            <input type="checkbox" name="rememberMe" class="form-check-input" id="remember">
            <label class="form-check-label" for="remember">Ghi nhớ đăng nhập</label>
        </div>

        <button type="submit" class="btn btn-primary w-100 fw-bold">ĐĂNG NHẬP</button>
    </form>
</div>

</body>
</html>