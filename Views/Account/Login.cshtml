@model PhoneStore.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập - SunMobile";
}

<style>
    /* Nền trang nhã hơn */
    body {
        background-color: #fcfcfc;
    }

    /* Thẻ đăng nhập tối giản */
    .login-card {
        border: none;
        border-radius: 30px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04) !important;
        padding: 3rem;
        max-width: 450px;
        width: 100%;
    }

    /* Ô nhập liệu tinh tế */
    .sun-input {
        background-color: #f8f9fa !important;
        border: 1px solid #eee !important;
        border-radius: 15px !important;
        padding: 12px 20px !important;
        font-size: 0.95rem;
        transition: all 0.3s;
    }

        .sun-input:focus {
            background-color: #fff !important;
            border-color: #f97316 !important; /* Màu cam SunMobile */
            box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.1) !important;
        }

    /* Nút bấm hiện đại */
    .btn-login {
        background: #000;
        color: #fff;
        border-radius: 15px;
        padding: 14px;
        font-weight: 700;
        border: none;
        transition: all 0.3s;
        margin-top: 1rem;
    }

        .btn-login:hover {
            background: #f97316;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(249, 115, 22, 0.3);
            color: #fff;
        }

    .brand-accent {
        color: #f97316;
    }

    .form-label {
        font-weight: 600;
        color: #444;
        margin-left: 5px;
        font-size: 0.85rem;
    }
</style>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="login-card">
        <div class="text-center mb-5">
            <h2 class="fw-black text-dark mb-1" style="letter-spacing: -1.5px;">
                Sun<span class="brand-accent">Mobile</span>
            </h2>
            <p class="text-muted small fw-bold text-uppercase" style="letter-spacing: 1px;">Đăng nhập hệ thống</p>
        </div>

        <form asp-controller="Account" asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center"></div>

            <div class="mb-4">
                <label asp-for="Email" class="form-label text-uppercase">Tài khoản Email</label>
                <input asp-for="Email" class="form-control sun-input" placeholder="name@example.com" required />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label text-uppercase">Mật khẩu</label>
                <input asp-for="Password" type="password" class="form-control sun-input" placeholder="••••••••" required />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4 px-1">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" type="checkbox" id="rememberMe">
                        <label class="form-check-label small text-muted fw-bold" for="rememberMe">Ghi nhớ</label>
                    </div>
                    <a href="#" class="small fw-bold text-decoration-none" style="color: #f97316;">Quên mật khẩu?</a>
                </div>

                <button type="submit" class="btn btn-login w-100">
                    Đăng nhập
                </button>

                <div class="text-center mt-5">
                    <p class="text-muted small fw-bold">
                        Chưa có tài khoản?
                        <a asp-action="Register" class="text-decoration-none ms-1 brand-accent">Tạo tài khoản mới</a>
                    </p>
                </div>
            </form>
        </div>
    </div>