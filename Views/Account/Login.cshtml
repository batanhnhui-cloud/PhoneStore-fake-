@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - PhoneStore</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
        body { background-color: #f4f7fc; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px 0;}
        .login-container { max-width: 400px; width: 100%; padding: 2.5rem; background: white; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); }
        .brand-logo { text-align: center; margin-bottom: 2rem; }
        .brand-logo i { font-size: 3rem; color: #0d6efd; }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="brand-logo">
            <i class="fa fa-mobile-alt"></i>
            <h3 class="mt-2 fw-bold text-primary">PHONESTORE</h3>
            <p class="text-muted small">Đăng nhập để tiếp tục</p>
        </div>

        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            <div asp-validation-summary="All" class="text-danger small mb-3 fw-bold text-center"></div>

            <div class="mb-3">
                <label class="form-label fw-bold text-secondary">Email đăng nhập</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="fa fa-envelope text-muted"></i></span>
                    <input type="email" name="email" class="form-control" placeholder="email@example.com" required />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold text-secondary">Mật khẩu</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="fa fa-lock text-muted"></i></span>
                    <input type="password" name="password" class="form-control" placeholder="••••••••" required />
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 fw-bold py-2 fs-5 shadow-sm">
                <i class="fa fa-sign-in-alt me-2"></i> ĐĂNG NHẬP
            </button>
            
            <div class="text-center mt-4 border-top pt-4">
                <p class="small text-muted mb-2">Chưa có tài khoản?</p>
                <a asp-action="Register" class="btn btn-outline-success btn-sm w-100 fw-bold rounded-pill mb-3 py-2">
                    <i class="fa fa-user-plus me-1"></i> Đăng ký tài khoản mới
                </a>
                <a href="/" class="text-decoration-none small text-muted hover-primary d-block mt-2">
                    <i class="fa fa-arrow-left me-1"></i> Quay lại trang chủ mua sắm
                </a>
            </div>
        </form>
    </div>
</body>
</html>