@model PhoneStore.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card shadow-lg border-0 rounded-5 overflow-hidden" style="max-width: 900px; width: 100%;">
        <div class="row g-0">
            <div class="col-md-6 p-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bolder text-dark mb-1">Chào mừng trở lại!</h2>
                    <p class="text-muted small">Đăng nhập để quản lý giỏ hàng và đơn hàng.</p>
                </div>

                <form asp-controller="Account" asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    
                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-bold text-muted small">EMAIL CỦA BẠN</label>
                        <div class="input-group input-group-lg shadow-sm">
                            <span class="input-group-text bg-light border-end-0"><i class="fa fa-envelope text-muted"></i></span>
                            <input asp-for="Email" class="form-control border-start-0 bg-light fs-6" placeholder="Nhập email..." required />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-bold text-muted small">MẬT KHẨU</label>
                        <div class="input-group input-group-lg shadow-sm">
                            <span class="input-group-text bg-light border-end-0"><i class="fa fa-lock text-muted"></i></span>
                            <input asp-for="Password" type="password" class="form-control border-start-0 bg-light fs-6" placeholder="Nhập mật khẩu..." required />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input shadow-sm" type="checkbox" id="rememberMe">
                                <label class="form-check-label small text-muted fw-bold" for="rememberMe">Ghi nhớ tôi</label>
                            </div>
                            <a href="#" class="small fw-bold text-decoration-none" style="color: #f97316;">Quên mật khẩu?</a>
                        </div>

                        <button type="submit" class="btn btn-sun btn-lg w-100 rounded-pill fw-bold shadow-sm mb-3">
                            <i class="fa fa-sign-in-alt me-2"></i> Đăng nhập ngay
                        </button>

                        <div class="text-center mt-4">
                            <p class="text-muted small fw-bold">Chưa có tài khoản? <a asp-action="Register" class="text-decoration-none ms-1" style="color: #f97316;">Đăng ký tại đây</a></p>
                        </div>
                    </form>
                </div>
                <div class="col-md-6 d-none d-md-block" style="background: linear-gradient(135deg, #f97316 0%, #fb923c 100%); position: relative;">
                    <div class="d-flex flex-column justify-content-center align-items-center h-100 text-white p-5 text-center position-relative z-index-1">
                        <i class="fa fa-sun fa-4x mb-3 text-white opacity-75"></i>
                        <h2 class="fw-bolder display-6">SunMobile</h2>
                        <p class="lead opacity-75">Hệ sinh thái công nghệ hàng đầu dành riêng cho bạn.</p>
                    </div>
                    <div class="position-absolute top-0 end-0 rounded-circle bg-white opacity-10" style="width: 200px; height: 200px; margin-top: -50px; margin-right: -50px;"></div>
                    <div class="position-absolute bottom-0 start-0 rounded-circle bg-dark opacity-10" style="width: 300px; height: 300px; margin-bottom: -100px; margin-left: -100px;"></div>
                </div>
            </div>
        </div>
    </div>