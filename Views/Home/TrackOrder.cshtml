@model IEnumerable<PhoneStore.Models.Order>
@{
    ViewData["Title"] = "Tra cứu Lịch sử mua hàng";
}

<style>
    /* CSS cho Thanh tiến độ đơn hàng (Timeline) */
    .tracking-timeline { position: relative; display: flex; justify-content: space-between; margin: 2rem 0; }
    .tracking-timeline::before { content: ''; position: absolute; top: 20px; left: 10%; right: 10%; height: 3px; background: #e2e8f0; z-index: 1; }
    .tracking-step { position: relative; z-index: 2; text-align: center; width: 33.33%; }
    .step-icon { width: 44px; height: 44px; border-radius: 50%; background: #e2e8f0; color: #94a3b8; line-height: 44px; margin: 0 auto 10px; font-size: 1.2rem; border: 4px solid #fff; box-shadow: 0 0 0 1px #e2e8f0; transition: all 0.3s; }
    .step-label { font-size: 0.85rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; }
    
    /* Trạng thái Active (Màu Cam) */
    .tracking-step.active .step-icon { background: linear-gradient(135deg, #f97316, #fb923c); color: #fff; box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.2); border-color: #fff; }
    .tracking-step.active .step-label { color: #f97316; }
    
    /* Trạng thái Hủy (Màu Đỏ) */
    .tracking-step.cancelled .step-icon { background: #ef4444; color: #fff; box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.2); border-color: #fff; }
    .tracking-step.cancelled .step-label { color: #ef4444; }
</style>

<div class="container mt-5 mb-5" style="min-height: 60vh;">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="text-center mb-5">
                <span class="badge px-4 py-2 rounded-pill mb-3 fw-bold shadow-sm border" style="background-color: #fff; color: #f97316; border-color: #f97316 !important;">
                    <i class="fa fa-shield-alt me-1"></i> BẢO HÀNH ĐIỆN TỬ
                </span>
                <h2 class="fw-bolder text-dark mb-3">Tra Cứu Giao Dịch</h2>
                <p class="text-muted fs-5">Theo dõi hành trình đơn hàng và thời hạn bảo hành qua IMEI.</p>
            </div>

            <div class="card shadow-sm border-0 rounded-4 mb-5">
                <div class="card-body p-4 p-md-5">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger fw-bold rounded-3 border-0 mb-4 shadow-sm"><i class="fa fa-exclamation-triangle me-2"></i> @ViewBag.Error</div>
                    }

                    <form asp-action="TrackOrder" method="post" class="row justify-content-center">
                        <div class="col-md-9">
                            <div class="input-group input-group-lg shadow-sm rounded-pill p-1 bg-white border">
                                <span class="input-group-text bg-transparent border-0 ms-3"><i class="fa fa-phone text-muted"></i></span>
                                <input type="text" name="phone" class="form-control border-0 fw-bold py-3 px-2 shadow-none" placeholder="Nhập số điện thoại mua hàng..." required autocomplete="off" />
                                <button type="submit" class="btn btn-sun rounded-pill px-5 fw-bold"><i class="fa fa-search me-2"></i>Tìm kiếm</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            @if (Model != null && Model.Any())
            {
                <h5 class="fw-bold mb-4 text-dark"><i class="fa fa-list-ul me-2 text-muted"></i>Lịch sử mua hàng (@Model.Count() đơn)</h5>
                
                foreach (var order in Model)
                {
                    <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-5">
                        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-0 fw-bold text-dark d-inline-block me-2">Đơn hàng #@order.Id</h5>
                                <span class="text-muted small"><i class="fa fa-clock me-1"></i>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <span class="fw-bold text-danger fs-5">@order.TotalAmount.ToString("N0") đ</span>
                        </div>
                        
                        <div class="card-body p-4 p-md-5">
                            
                            <div class="tracking-timeline mb-5">
                                @if (order.Status == "Cancelled")
                                {
                                    <div class="tracking-step cancelled">
                                        <div class="step-icon"><i class="fa fa-times"></i></div>
                                        <div class="step-label">Đã Hủy Đơn</div>
                                    </div>
                                }
                                else
                                {
                                    <div class="tracking-step @(order.Status == "Pending" || order.Status == "Success" ? "active" : "")">
                                        <div class="step-icon"><i class="fa fa-clipboard-list"></i></div>
                                        <div class="step-label">Chờ Xử Lý</div>
                                    </div>
                                    <div class="tracking-step @(order.Status == "Success" ? "active" : "")">
                                        <div class="step-icon"><i class="fa fa-box-open"></i></div>
                                        <div class="step-label">Đã Xuất Kho</div>
                                    </div>
                                    <div class="tracking-step @(order.Status == "Success" ? "active" : "")">
                                        <div class="step-icon"><i class="fa fa-check"></i></div>
                                        <div class="step-label">Hoàn Thành</div>
                                    </div>
                                }
                            </div>

                            <div class="table-responsive mb-4 rounded-3 border">
                                <table class="table table-borderless align-middle mb-0">
                                    <thead class="table-light text-muted small">
                                        <tr>
                                            <th class="ps-4 py-3">SẢN PHẨM</th>
                                            <th class="text-center py-3">SL</th>
                                            <th class="text-end pe-4 py-3">ĐƠN GIÁ</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in order.OrderDetails)
                                        {
                                            <tr class="border-bottom">
                                                <td class="fw-bold text-dark ps-4 py-3">@item.Product?.Name</td>
                                                <td class="text-center py-3">@item.Quantity</td>
                                                <td class="text-end text-danger fw-bold pe-4 py-3">@item.Price.ToString("N0") đ</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            @if (order.Status == "Success" && order.DeviceImeis != null && order.DeviceImeis.Any())
                            {
                                <div class="bg-light p-4 rounded-4 border">
                                    <h6 class="fw-bolder mb-3 text-success"><i class="fa fa-shield-alt me-2"></i>THÔNG TIN BẢO HÀNH ĐIỆN TỬ (IMEI)</h6>
                                    <div class="row g-3">
                                        @foreach (var device in order.DeviceImeis)
                                        {
                                            <div class="col-md-6">
                                                <div class="bg-white p-3 rounded-3 border-start border-success border-4 shadow-sm d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <span class="fw-bold text-dark font-monospace fs-6">@device.Imei</span><br/>
                                                        <small class="text-muted">Kích hoạt: @device.WarrantyActivationDate?.ToString("dd/MM/yyyy")</small>
                                                    </div>
                                                    <div class="text-end">
                                                        <span class="badge bg-success rounded-pill px-2 mb-1">Hạn bảo hành</span><br/>
                                                        <span class="fw-bold text-danger">@device.WarrantyExpirationDate?.ToString("dd/MM/yyyy")</span>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>