@using Microsoft.AspNetCore.Mvc.Rendering
@model IEnumerable<PhoneStore.Models.Product>
@{
    ViewData["Title"] = "Điện thoại - SunMobile";
}

<style>
    .product-card { transition: all 0.3s ease; border: 1px solid rgba(0,0,0,0.05); }
    .product-card:hover { transform: translateY(-8px); box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important; border-color: rgba(249, 115, 22, 0.3); }
    .product-img-wrapper { overflow: hidden; padding: 1.5rem; background: #fff; }
    .product-img-wrapper img { transition: transform 0.5s ease; }
    .product-card:hover .product-img-wrapper img { transform: scale(1.08); }
    .btn-buy-now { background: rgba(249, 115, 22, 0.1); color: #f97316; font-weight: bold; transition: all 0.3s; }
    .product-card:hover .btn-buy-now { background: linear-gradient(135deg, #f97316, #fb923c); color: white; }
    .product-title { color: #1e293b; text-decoration: none; transition: color 0.2s; font-size: 1.1rem; }
    .product-card:hover .product-title { color: #f97316; }
</style>

<div class="rounded-5 p-4 p-md-5 mb-5 shadow-sm text-center text-white" style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);">
    <h1 class="fw-bolder display-5 mb-2">☀️ SunMobile</h1>
    <p class="lead opacity-75 mb-0">Hệ thống bán lẻ điện thoại chính hãng - Bảo hành IMEI toàn quốc.</p>
</div>

<div class="card shadow-sm border-0 rounded-4 mb-5 bg-white">
    <div class="card-body p-4">
        <form asp-controller="Home" asp-action="Shop" method="get" class="row g-3 align-items-center">
            <div class="col-md-5">
                <div class="input-group input-group-lg shadow-sm rounded-pill p-1 border">
                    <span class="input-group-text bg-transparent border-0"><i class="fa fa-search text-muted ms-2"></i></span>
                    <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="form-control border-0 shadow-none fs-6" placeholder="Tìm tên máy (iPhone, Samsung...)" />
                </div>
            </div>
            <div class="col-md-4">
                <div class="input-group input-group-lg shadow-sm rounded-pill p-1 border bg-light">
                    <span class="input-group-text bg-transparent border-0"><i class="fa fa-filter text-muted ms-2"></i></span>
                    <select name="categoryId" class="form-select border-0 bg-transparent shadow-none fs-6" asp-items="(IEnumerable<SelectListItem>)ViewBag.Categories">
                        <option value="">-- Tất cả các hãng --</option>
                    </select>
                </div>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-lg w-100 rounded-pill text-white fw-bold shadow-sm" style="background: linear-gradient(135deg, #f97316, #fb923c); border: none;">
                    Lọc sản phẩm
                </button>
            </div>
        </form>
    </div>
</div>

<div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4 mb-5">
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <i class="fa fa-search-minus fs-1 text-muted mb-3"></i>
            <h5 class="text-muted fw-bold">Không tìm thấy sản phẩm nào phù hợp với yêu cầu của bạn.</h5>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 product-card rounded-4 bg-white shadow-sm border-0">
                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="product-img-wrapper d-block text-center rounded-top-4">
                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/300x300?text=SunMobile" : item.ImageUrl)" 
                             class="img-fluid object-fit-contain" style="height: 200px;" alt="@item.Name">
                    </a>
                    
                    <div class="card-body d-flex flex-column p-4">
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                            <h5 class="product-title fw-bold mb-2 text-truncate">@item.Name</h5>
                        </a>
                        
                        <div class="mt-auto">
                            <span class="fs-5 fw-bolder text-danger d-block mb-3">@item.Price.ToString("N0") đ</span>
                            <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                <input type="hidden" name="productId" value="@item.Id" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn-buy-now w-100 rounded-pill py-2 shadow-sm">
                                    <i class="fa fa-cart-plus me-1"></i> Chọn mua
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>