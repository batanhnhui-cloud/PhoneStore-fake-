@model IEnumerable<PhoneStore.Models.Product>
@{
    ViewData["Title"] = "Tất cả điện thoại";
}

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h2 class="fw-bolder text-dark mb-0"><i class="fa fa-mobile-alt text-primary me-2"></i>Điện thoại chính hãng</h2>
        <p class="text-muted mt-1 mb-0">Tìm thấy <strong class="text-primary">@Model.Count()</strong> sản phẩm phù hợp.</p>
    </div>
    <div class="col-md-6 text-md-end mt-3 mt-md-0">
        <form asp-action="Shop" method="get" class="d-inline-flex w-100" style="max-width: 350px;">
            <input type="hidden" name="categoryId" value="@ViewBag.CurrentCategory" />
            <div class="input-group shadow-sm">
                <input type="text" name="searchString" class="form-control border-0 bg-white rounded-start-pill ps-4" placeholder="Tìm tên máy..." value="@ViewBag.CurrentSearch">
                <button type="submit" class="btn btn-primary rounded-end-pill px-4"><i class="fa fa-search"></i></button>
            </div>
        </form>
    </div>
</div>

<div class="row">
    <div class="col-lg-3 mb-4">
        <div class="card shadow-sm border-0 sticky-top" style="top: 100px;">
            <div class="card-header bg-white border-bottom fw-bold py-3 fs-5"><i class="fa fa-filter text-primary me-2"></i> Lọc theo hãng</div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush rounded-bottom-4">
                    <a asp-action="Shop" asp-route-searchString="@ViewBag.CurrentSearch" class="list-group-item list-group-item-action py-3 fw-bold @(ViewBag.CurrentCategory == null ? "bg-primary bg-opacity-10 text-primary border-start border-4 border-primary" : "text-dark")">Tất cả hãng máy</a>
                    @if (ViewBag.Categories != null)
                    {
                        foreach (var cat in ViewBag.Categories)
                        {
                            <a asp-action="Shop" asp-route-categoryId="@cat.Id" asp-route-searchString="@ViewBag.CurrentSearch" class="list-group-item list-group-item-action py-3 fw-bold @(ViewBag.CurrentCategory == cat.Id ? "bg-primary bg-opacity-10 text-primary border-start border-4 border-primary" : "text-dark")">@cat.Name</a>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-9">
        @if (!Model.Any())
        {
            <div class="text-center py-5 bg-white rounded-4 shadow-sm border-0">
                <i class="fa fa-search-minus fa-4x text-muted mb-3 opacity-50"></i>
                <h4 class="text-muted fw-bold">Không tìm thấy sản phẩm nào!</h4>
                <a asp-action="Shop" class="btn btn-primary rounded-pill px-4 mt-3 fw-bold shadow-sm">Xem tất cả sản phẩm</a>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card h-100 product-card border-0 p-2 position-relative shadow-sm">
                            
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                                <div class="bg-light rounded-4 d-flex justify-content-center align-items-center p-4 mb-3" style="height: 220px;">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" class="img-fluid" alt="@item.Name" style="max-height: 100%; object-fit: contain; mix-blend-mode: multiply;">
                                    }
                                    else
                                    {
                                        <i class="fa fa-mobile-alt fa-4x text-muted opacity-25"></i>
                                    }
                                </div>
                            </a>
                            
                            <div class="card-body p-3 d-flex flex-column">
                                <div class="text-muted small fw-bold text-uppercase mb-1">@item.Category?.Name</div>
                                
                                <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                                    <h6 class="fw-bold text-dark text-truncate mb-2" title="@item.Name">@item.Name</h6>
                                </a>
                                
                                <div class="mt-auto pt-3 d-flex justify-content-between align-items-center border-top">
                                    <h5 class="text-danger fw-bolder mb-0 fs-5">@item.Price.ToString("N0")<small class="text-muted fs-6">đ</small></h5>
                                    
                                    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="m-0">
                                        <input type="hidden" name="productId" value="@item.Id" />
                                        <input type="hidden" name="quantity" value="1" />
                                        <button type="submit" class="btn btn-dark rounded-circle shadow-sm" style="width: 40px; height: 40px; padding: 0;" title="Thêm vào giỏ"><i class="fa fa-cart-plus"></i></button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>