@model IEnumerable<PhoneStore.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="container mt-4 mb-5" style="min-height: 50vh;">
    <h2 class="fw-bolder text-dark mb-4"><i class="fa fa-box-open text-primary me-2"></i>Lịch sử mua hàng</h2>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Mã đơn</th>
                            <th>Ngày đặt</th>
                            <th>Sản phẩm</th>
                            <th>Tổng tiền</th>
                            <th class="text-end pe-4">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <i class="fa fa-shopping-bag fa-3x text-muted mb-3 opacity-50"></i>
                                    <h5 class="fw-bold text-muted">Bạn chưa có đơn hàng nào</h5>
                                    <a asp-controller="Home" asp-action="Shop" class="btn btn-outline-primary mt-3 rounded-pill fw-bold px-4 shadow-sm">Bắt đầu mua sắm ngay</a>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-primary">#@item.Id</td>
                                    <td class="text-muted small fw-semibold">@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <ul class="list-unstyled mb-0 small">
                                            @foreach (var detail in item.OrderDetails)
                                            {
                                                <li><i class="fa fa-caret-right text-muted me-1"></i>@detail.Product?.Name <span class="fw-bold text-danger ms-1">x @(detail.Quantity)</span></li>
                                            }
                                        </ul>
                                    </td>
                                    <td class="text-danger fw-bold fs-6">@item.TotalAmount.ToString("N0")<small class="text-muted ms-1">đ</small></td>
                                    <td class="text-end pe-4">
                                        @{
                                            var badgeClass = item.Status switch
                                            {
                                                "Pending" => "bg-warning text-dark",
                                                "Success" => "bg-success",
                                                "Cancelled" => "bg-danger",
                                                _ => "bg-secondary"
                                            };
                                            var statusText = item.Status switch
                                            {
                                                "Pending" => "Đang xử lý",
                                                "Success" => "Hoàn thành",
                                                "Cancelled" => "Đã hủy",
                                                _ => item.Status
                                            };
                                        }
                                        <span class="badge @badgeClass px-3 py-2 shadow-sm rounded-pill">@statusText</span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>