@model IEnumerable<PhoneStore.Models.Product>
@{
    ViewData["Title"] = "Trang chủ";
}

<style>
    .product-card { transition: all 0.3s ease; border: 1px solid rgba(0,0,0,0.05); }
    .product-card:hover { transform: translateY(-8px); box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important; border-color: rgba(249, 115, 22, 0.3); }
    .product-img-wrapper { overflow: hidden; padding: 1.5rem; background: #fff; }
    .product-img-wrapper img { transition: transform 0.5s ease; }
    .product-card:hover .product-img-wrapper img { transform: scale(1.08); }
    .btn-buy-now { background: rgba(249, 115, 22, 0.1); color: #f97316; font-weight: bold; transition: all 0.3s; }
    .product-card:hover .btn-buy-now { background: linear-gradient(135deg, #f97316, #fb923c); color: white; }
    .product-title { color: #1e293b; text-decoration: none; transition: color 0.2s; }
    .product-card:hover .product-title { color: #f97316; }
</style>

<div class="row align-items-center bg-dark text-white rounded-5 p-4 p-lg-5 mb-5 shadow-lg position-relative overflow-hidden" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);">
    <div class="position-absolute top-0 end-0 translate-middle-y rounded-circle" style="width: 300px; height: 300px; background: radial-gradient(circle, rgba(249,115,22,0.2) 0%, rgba(0,0,0,0) 70%);"></div>
    
    <div class="col-lg-6 position-relative z-index-1">
        <span class="badge bg-warning text-dark px-3 py-2 rounded-pill mb-3 fw-bold tracking-wide">SIÊU PHẨM 2026</span>
        <h1 class="display-4 fw-bolder mb-3">Công nghệ đỉnh cao.<br/><span style="color: #f97316;">Nằm trong tay bạn.</span></h1>
        <p class="lead opacity-75 mb-4">Khám phá các dòng smartphone đời mới nhất với hệ thống quản lý bảo hành qua IMEI độc quyền tại SunMobile.</p>
        <a href="#productList" class="btn btn-lg px-5 py-3 rounded-pill text-white fw-bold shadow-sm" style="background: linear-gradient(135deg, #f97316, #fb923c); border: none;">
            Khám phá ngay <i class="fa fa-arrow-down ms-2"></i>
        </a>
    </div>
    <div class="col-lg-6 text-center mt-5 mt-lg-0 d-none d-md-block">
        <img src="https://fdn2.gsmarena.com/vv/pics/apple/apple-iphone-15-pro-max-1.jpg" alt="Hero Phone" class="img-fluid rounded-4 shadow-lg" style="max-height: 400px; transform: rotate(-10deg) scale(1.1); mix-blend-mode: lighten;" />
    </div>
</div>

<div class="row g-4 mb-5 text-center">
    <div class="col-md-4">
        <div class="card bg-white border-0 shadow-sm rounded-4 h-100 py-3">
            <div class="card-body">
                <i class="fa fa-shield-alt fs-1 text-primary mb-3"></i>
                <h5 class="fw-bold text-dark">Bảo hành trọn đời</h5>
                <p class="text-muted small mb-0">Quản lý bảo hành điện tử thông minh qua mã số IMEI duy nhất.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-white border-0 shadow-sm rounded-4 h-100 py-3">
            <div class="card-body">
                <i class="fa fa-rocket fs-1 mb-3" style="color: #f97316;"></i>
                <h5 class="fw-bold text-dark">Giao hàng hỏa tốc</h5>
                <p class="text-muted small mb-0">Hệ thống luân chuyển kho thông minh, nhận máy trong 2 giờ.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-white border-0 shadow-sm rounded-4 h-100 py-3">
            <div class="card-body">
                <i class="fa fa-sync-alt fs-1 text-success mb-3"></i>
                <h5 class="fw-bold text-dark">Đổi trả dễ dàng</h5>
                <p class="text-muted small mb-0">Miễn phí 1 đổi 1 trong vòng 30 ngày nếu có lỗi từ nhà sản xuất.</p>
            </div>
        </div>
    </div>
</div>

<div id="productList" class="d-flex justify-content-between align-items-end mb-4 pb-2 border-bottom">
    <h3 class="fw-bolder text-dark mb-0"><i class="fa fa-fire text-danger me-2"></i>Sản Phẩm Nổi Bật</h3>
</div>

<div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4 mb-5">
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <i class="fa fa-box-open fs-1 text-muted mb-3"></i>
            <h5 class="text-muted fw-bold">Hiện tại chưa có sản phẩm nào.</h5>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 product-card rounded-4 bg-white">
                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="product-img-wrapper d-block text-center rounded-top-4">
                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/300x300?text=No+Image" : item.ImageUrl)" 
                             class="img-fluid object-fit-contain" style="height: 220px;" alt="@item.Name">
                    </a>
                    <div class="card-body d-flex flex-column p-4 border-top">
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                            <h5 class="product-title fw-bold mb-2 text-truncate" title="@item.Name">@item.Name</h5>
                        </a>
                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="fs-5 fw-bolder text-danger">@item.Price.ToString("N0") <small class="text-muted text-decoration-line-through fs-6 ms-1">@((item.Price * 1.1m).ToString("N0"))</small></span>
                            </div>
                            <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                <input type="hidden" name="productId" value="@item.Id" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn-buy-now w-100 rounded-pill py-2">
                                    <i class="fa fa-cart-plus me-1"></i> Đặt mua ngay
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>