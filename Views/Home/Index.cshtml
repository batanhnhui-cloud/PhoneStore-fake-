@using Microsoft.AspNetCore.Mvc.Rendering
@model IEnumerable<PhoneStore.Models.Product>
@{
    ViewData["Title"] = "Cửa hàng - SunMobile";
}

<style>
    :root {
        --sun-orange: #f97316;
        --sun-orange-light: #fb923c;
        --sun-dark: #1e293b;
        --sun-darker: #0f172a;
    }

    .product-card { transition: all 0.3s cubic-bezier(.25,.8,.25,1); border: 1px solid rgba(0,0,0,0.03); }
    .product-card:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.1) !important; border-color: rgba(249, 115, 22, 0.2); }
    
    .product-img-wrapper { overflow: hidden; padding: 2rem; background: #fff; position: relative; }
    .product-img-wrapper img { transition: transform 0.6s ease; object-fit: contain; height: 200px; width: 100%; }
    .product-card:hover .product-img-wrapper img { transform: scale(1.1); }
    
    .btn-buy-now { background: rgba(249, 115, 22, 0.1); color: var(--sun-orange); font-weight: 700; border: none; transition: all 0.3s; }
    .product-card:hover .btn-buy-now { background: linear-gradient(135deg, var(--sun-orange), var(--sun-orange-light)); color: white; }
    
    .product-title { color: var(--sun-dark); text-decoration: none; transition: color 0.2s; font-size: 1.15rem; height: 2.8rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .product-card:hover .product-title { color: var(--sun-orange); }

    .search-pill { border: 1px solid #e2e8f0; transition: all 0.3s; }
    .search-pill:focus-within { border-color: var(--sun-orange); box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.1); }
</style>

<div class="rounded-5 p-5 mb-5 shadow-lg text-center text-white" style="background: linear-gradient(135deg, var(--sun-dark) 0%, var(--sun-darker) 100%);">
    <div class="py-3">
        <h1 class="fw-bolder display-4 mb-3"><i class="fa fa-sun text-warning me-2"></i>SunMobile</h1>
        <p class="lead opacity-75 mb-0 fs-4">Đẳng cấp công nghệ - Bảo hành IMEI toàn quốc</p>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4 mb-5 bg-white">
    <div class="card-body p-4">
        <form asp-action="Index" method="get" class="row g-3 align-items-center">
            <div class="col-md-5">
                <div class="input-group input-group-lg search-pill rounded-pill p-1 bg-white">
                    <span class="input-group-text bg-transparent border-0"><i class="fa fa-search text-muted ms-2"></i></span>
                    <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="form-control border-0 shadow-none fs-6" placeholder="Bạn tìm iPhone 16, Samsung S25..." />
                </div>
            </div>
            <div class="col-md-4">
                <div class="input-group input-group-lg search-pill rounded-pill p-1 bg-light">
                    <span class="input-group-text bg-transparent border-0"><i class="fa fa-filter text-muted ms-2"></i></span>
                    <select name="categoryId" class="form-select border-0 bg-transparent shadow-none fs-6" asp-items="(IEnumerable<SelectListItem>)ViewBag.Categories">
                        <option value="">Tất cả các hãng</option>
                    </select>
                </div>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-lg w-100 rounded-pill text-white fw-bold shadow-sm" style="background: linear-gradient(135deg, var(--sun-orange), var(--sun-orange-light)); border: none;">
                    Lọc ngay
                </button>
            </div>
        </form>
    </div>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 mb-5">
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <div class="py-5 bg-light rounded-5">
                <i class="fa fa-ghost fs-1 text-muted mb-3 d-block"></i>
                <h5 class="text-muted fw-bold">Ối! SunMobile chưa có máy này rồi...</h5>
                <a href="/" class="btn btn-link text-orange text-decoration-none">Xem tất cả sản phẩm</a>
            </div>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 product-card rounded-4 bg-white shadow-sm border-0">
                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="product-img-wrapper d-block text-center rounded-top-4">
                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/300x300?text=SunMobile" : item.ImageUrl)" alt="@item.Name">
                    </a>
                    
                    <div class="card-body d-flex flex-column p-4">
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                            <h5 class="product-title fw-bold mb-3">@item.Name</h5>
                        </a>
                        
                        <div class="mt-auto">
                            <div class="d-flex align-items-baseline mb-3">
                                <span class="fs-4 fw-bolder text-danger">@item.Price.ToString("N0")</span>
                                <span class="ms-1 fw-bold text-danger">đ</span>
                            </div>
                            <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                <input type="hidden" name="productId" value="@item.Id" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn-buy-now w-100 rounded-pill py-2 shadow-sm">
                                    <i class="fa fa-cart-plus me-1"></i> Chọn mua
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>