@model IEnumerable<PhoneStore.Models.Product>
@{
    ViewData["Title"] = "Trang chủ";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success fw-bold shadow-lg rounded-4 alert-dismissible fade show border-0 my-4" role="alert">
        <i class="fa fa-check-circle me-2 fs-5"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        <a asp-controller="Cart" asp-action="Index" class="btn btn-dark btn-sm ms-3 fw-bold rounded-pill px-3">XEM GIỎ HÀNG <i class="fa fa-arrow-right ms-1"></i></a>
    </div>
}

<div class="card bg-dark text-white border-0 rounded-4 overflow-hidden mb-5 shadow-lg position-relative" style="min-height: 400px;">
    <div class="position-absolute w-100 h-100" style="background: linear-gradient(45deg, #0f172a 0%, #3b82f6 100%); opacity: 0.9;"></div>
    
    <div class="card-img-overlay d-flex flex-column justify-content-center align-items-center text-center p-5 z-1">
        <span class="badge bg-white text-primary mb-3 px-3 py-2 fs-6 rounded-pill shadow">ĐỘC QUYỀN MÙA HÈ 2026</span>
        <h1 class="display-3 fw-bolder mb-3" style="letter-spacing: -1px;">Vượt Qua Mọi Giới Hạn.</h1>
        <p class="fs-5 fw-light text-white-50 w-75 mb-4">Sở hữu những siêu phẩm công nghệ với mức giá không tưởng. Miễn phí giao hàng toàn quốc.</p>
        <a href="#trending" class="btn btn-light btn-lg text-primary fw-bold rounded-pill px-5 shadow-lg py-3">Khám phá ngay</a>
    </div>
</div>

<div id="trending" class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h2 class="fw-bolder text-dark mb-0">Sản phẩm Xu hướng</h2>
        <p class="text-muted mt-1 mb-0">Những mẫu điện thoại được săn đón nhiều nhất.</p>
    </div>
    <a asp-action="Shop" class="text-primary fw-bold text-decoration-none border-bottom border-2 border-primary pb-1">Xem tất cả <i class="fa fa-arrow-right ms-1"></i></a>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4 mb-5">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 product-card border-0 p-2 position-relative">
                    <span class="badge bg-danger position-absolute top-0 start-0 m-3 z-1">HOT</span>
                    
                    <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                        <div class="bg-light rounded-4 d-flex justify-content-center align-items-center p-4 mb-3" style="height: 250px;">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="img-fluid" alt="@item.Name" style="max-height: 100%; object-fit: contain; mix-blend-mode: multiply;">
                            }
                            else
                            {
                                <i class="fa fa-mobile-alt fa-5x text-muted opacity-25"></i>
                            }
                        </div>
                    </a>
                    
                    <div class="card-body p-3 d-flex flex-column">
                        <div class="text-muted small fw-bold text-uppercase mb-1">@item.Category?.Name</div>
                        <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                            <h5 class="fw-bold text-dark text-truncate mb-2" title="@item.Name">@item.Name</h5>
                        </a>
                        
                        <div class="mt-auto pt-3 d-flex justify-content-between align-items-center">
                            <h5 class="text-primary fw-bolder mb-0">@item.Price.ToString("N0")<small class="text-muted fs-6">đ</small></h5>
                            
                            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="m-0">
                                <input type="hidden" name="productId" value="@item.Id" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn-dark rounded-circle" style="width: 45px; height: 45px; padding: 0;" title="Thêm vào giỏ"><i class="fa fa-plus"></i></button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>