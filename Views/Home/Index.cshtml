@model IEnumerable<PhoneStore.Models.Product>
@{
    ViewData["Title"] = "SunMobile - Trang chủ";
}

<style>
    body { background-color: #ffffff; color: #1d1d1f; }
    
    /* --- HERO ĐƯỢC THIẾT KẾ LẠI ĐẸP HƠN --- */
    .hero-clean { padding: 120px 0 80px 0; text-align: center; }
    
    .display-hero { 
        font-weight: 900; 
        letter-spacing: -2.5px; 
        line-height: 1.1; 
        font-size: 4.5rem; 
    }
    
    .text-highlight {
        color: #f97316; /* Cam SunMobile */
    }

    .hero-subtitle {
        font-size: 1.2rem;
        color: #666;
        font-weight: 500;
        margin-top: 20px;
        letter-spacing: 0.5px;
    }

    /* --- NÚT BẤM HERO --- */
    .btn-hero {
        padding: 14px 35px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .btn-hero-primary {
        background: #1d1d1f;
        color: #fff;
        border: 2px solid #1d1d1f;
    }

    .btn-hero-primary:hover {
        background: #f97316;
        border-color: #f97316;
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(249, 115, 22, 0.2);
    }

    .btn-hero-secondary {
        background: transparent;
        color: #1d1d1f;
        border: 2px solid #e0e0e0;
    }

    .btn-hero-secondary:hover {
        border-color: #1d1d1f;
        background: #fdfdfd;
        transform: translateY(-3px);
    }

    /* --- SẢN PHẨM --- */
    .sun-product-card { border: none; background: transparent; transition: transform 0.3s ease; text-align: center; margin-bottom: 30px; }
    .sun-product-card:hover { transform: translateY(-8px); }
    .img-frame {
        background: #f8f8f8; border-radius: 20px; padding: 25px; margin-bottom: 15px;
        display: flex; align-items: center; justify-content: center; height: 240px;
    }
    .img-frame img { max-height: 100%; object-fit: contain; transition: transform 0.4s; }
    .sun-product-card:hover .img-frame img { transform: scale(1.05); }
    .product-link { font-weight: 600; font-size: 1rem; color: #1d1d1f; text-decoration: none; display: block; margin-bottom: 5px; }
    .product-price { font-weight: 800; font-size: 1.1rem; color: #000; }
    .btn-action-bag {
        background: none; border: none; border-bottom: 2px solid #111; padding: 0; font-size: 0.8rem;
        font-weight: 800; text-transform: uppercase; letter-spacing: 1px; margin-top: 12px; transition: 0.3s;
    }
    .btn-action-bag:hover { color: #f97316; border-color: #f97316; }
</style>

<div class="container mb-5">
    <section class="hero-clean">
        <h1 class="display-hero text-dark">
            Điện thoại chính hãng.<br>
            <span class="text-highlight">Bảo hành thông minh.</span>
        </h1>
        <p class="hero-subtitle">
            Hệ thống quản lý chất lượng và hậu mãi qua mã IMEI độc quyền.
        </p>
        
        <div class="d-flex justify-content-center gap-3 mt-5">
            <a href="#productList" class="btn-hero btn-hero-primary text-decoration-none">Khám phá sản phẩm</a>
            <a asp-controller="Home" asp-action="TrackImei" class="btn-hero btn-hero-secondary text-decoration-none">
                <i class="fa fa-search me-2"></i> Tra cứu IMEI
            </a>
        </div>
    </section>

    <div class="row row-cols-2 row-cols-md-4 g-4 pt-4" id="productList">
        @if (Model != null)
        {
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="sun-product-card">
                        <div class="img-frame">
                            <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id">
                                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/300x300?text=SunMobile" : item.ImageUrl)" alt="@item.Name">
                            </a>
                        </div>
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="product-link text-truncate">@item.Name</a>
                        <div class="product-price">@item.Price.ToString("N0") đ</div>
                        <form asp-controller="Cart" asp-action="AddToCart" method="post">
                            <input type="hidden" name="productId" value="@item.Id" />
                            <input type="hidden" name="quantity" value="1" />
                            <button type="submit" class="btn-action-bag">Thêm vào túi</button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>
</div>