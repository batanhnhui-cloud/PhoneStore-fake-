@model IEnumerable<PhoneStore.Models.Product>
@{
    ViewData["Title"] = "Trang chủ";
}

<div class="bg-primary text-white py-5 mb-5 rounded-4 shadow-sm text-center" style="background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);">
    <h1 class="fw-bold display-4 mb-3"><i class="fa fa-rocket me-3"></i>SIÊU BÃO MUA SẮM 2026</h1>
    <p class="lead fs-4">Chào mừng bạn đến với hệ thống bán lẻ PhoneStore cao cấp nhất toàn quốc.</p>
</div>

<div class="d-flex justify-content-between align-items-center mb-4 mt-5">
    <h3 class="fw-bold text-dark text-uppercase"><i class="fa fa-fire text-danger me-2"></i>Điện thoại nổi bật</h3>
    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary rounded-pill fw-bold px-4">Xem tất cả</a>
</div>

<div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4 mb-5">
    @if(Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 product-card">
                    <div class="position-relative text-center bg-white rounded-top" style="padding: 20px;">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top img-fluid" alt="@item.Name" style="height: 200px; object-fit: contain;">
                        }
                        else
                        {
                            <div class="d-flex justify-content-center align-items-center bg-light rounded" style="height: 200px;">
                                <i class="fa fa-mobile-alt fa-5x text-muted opacity-50"></i>
                            </div>
                        }
                        <span class="badge bg-danger position-absolute top-0 start-0 m-3 px-2 py-1 shadow-sm">MỚI</span>
                    </div>
                    
                    <div class="card-body d-flex flex-column text-center bg-light">
                        <h6 class="card-title fw-bold text-dark text-truncate mb-3" title="@item.Name">@item.Name</h6>
                        
                        <div class="mt-auto">
                            <h5 class="text-danger fw-bold mb-3">@item.Price.ToString("N0") đ</h5>
                            <div class="d-grid gap-2">
                                <button class="btn btn-primary fw-bold py-2 shadow-sm" onclick="alert('Tính năng Giỏ hàng sẽ được kích hoạt ở bước tiếp theo!')">
                                    <i class="fa fa-cart-plus me-1"></i> THÊM GIỎ HÀNG
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <i class="fa fa-box-open fa-4x text-muted mb-3"></i>
            <h5 class="text-muted fw-bold">Hệ thống đang cập nhật sản phẩm. Vui lòng quay lại sau!</h5>
        </div>
    }
</div>

<style>
    .product-card { 
        transition: transform 0.3s ease, box-shadow 0.3s ease; 
        border-radius: 12px;
        overflow: hidden;
    }
    .product-card:hover { 
        transform: translateY(-8px); 
        box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important; 
    }
</style>