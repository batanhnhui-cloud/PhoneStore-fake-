@model IEnumerable<PhoneStore.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng của bạn";
}

<div class="container mt-4">
    <div class="p-3 mb-4 bg-light rounded shadow-sm border-start border-4 border-primary">
        <h2 class="mb-0 text-primary fw-bold">🛒 GIỎ HÀNG CỦA BẠN</h2>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-bordered align-middle mb-0">
                <thead class="table-dark text-center">
                    <tr>
                        <th style="width: 40%">Sản phẩm</th>
                        <th>Hình ảnh</th>
                        <th>Giá bán</th>
                        <th>Số lượng</th>
                        <th>Thành tiền</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.ProductName</td>
                            <td class="text-center">
                                <img src="@item.Image" width="80" class="img-thumbnail rounded shadow-sm" />
                            </td>
                            <td class="text-end">@item.Price.ToString("N0") đ</td>
                            <td class="text-center">
                                <span class="badge bg-secondary fs-6">@item.Quantity</span>
                            </td>
                            <td class="text-end fw-bold text-danger">@item.Total.ToString("N0") đ</td>
                            <td class="text-center">
                                <a asp-action="RemoveFromCart" asp-route-id="@item.ProductId"
                                   class="btn btn-outline-danger btn-sm"
                                   onclick="return confirm('Bạn muốn xóa sản phẩm này?')">Xóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <td colspan="4" class="text-end fw-bold h4 py-3">TỔNG CỘNG THANH TOÁN:</td>
                        <td colspan="2" class="text-danger fw-bold h4 py-3 text-center">@ViewBag.Total.ToString("N0") VNĐ</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="d-flex justify-content-between mt-4 mb-5">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg shadow-sm">
                ← Tiếp tục mua sắm
            </a>
            @* ĐÂY LÀ NÚT LIÊN KẾT ĐẾN BƯỚC THANH TOÁN *@
            <a asp-controller="Order" asp-action="Checkout" class="btn btn-success btn-lg px-5 fw-bold shadow">
                TIẾN HÀNH THANH TOÁN →
            </a>
        </div>
    }
    else
    {
        <div class="text-center py-5 shadow-sm rounded bg-white border">
            <div style="font-size: 80px;">Empty 🛒</div>
            <h4 class="mt-3 text-muted">Giỏ hàng của bạn đang trống!</h4>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg mt-3 px-5">Quay lại mua máy ngay</a>
        </div>
    }
</div>