@model IEnumerable<PhoneStore.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng của bạn";
    // Tính tổng tiền dựa trên thuộc tính Total bạn đã viết sẵn trong Model
    decimal totalCart = Model?.Sum(i => i.Total) ?? 0;
}

<div class="container my-5" style="min-height: 60vh;">
    <div class="d-flex align-items-center mb-4">
        <h2 class="fw-bolder text-dark mb-0"><i class="fa fa-shopping-bag me-2" style="color: #f97316;"></i> Giỏ Hàng</h2>
        <span class="badge bg-dark rounded-pill ms-3 fs-6 px-3 py-2">@(Model?.Sum(i => i.Quantity) ?? 0) sản phẩm</span>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="card shadow-sm border-0 rounded-5 py-5 text-center">
            <div class="card-body py-5">
                <i class="fa fa-cart-arrow-down fs-1 text-muted opacity-50 mb-4" style="font-size: 5rem !important;"></i>
                <h4 class="fw-bold text-dark mb-3">Giỏ hàng của bạn đang trống</h4>
                <p class="text-muted mb-4">Vẫn còn rất nhiều sản phẩm công nghệ đang chờ bạn khám phá.</p>
                <a asp-controller="Home" asp-action="Shop" class="btn btn-lg rounded-pill px-5 text-white fw-bold shadow-sm" style="background: linear-gradient(135deg, #f97316, #fb923c); border: none;">
                    Tiếp tục mua sắm
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-muted small">
                                <tr>
                                    <th class="ps-4 py-3" colspan="2">SẢN PHẨM</th>
                                    <th class="py-3 text-center">ĐƠN GIÁ</th>
                                    <th class="py-3 text-center" style="width: 150px;">SỐ LƯỢNG</th>
                                    <th class="py-3 text-end pe-4">THÀNH TIỀN</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr class="border-bottom">
                                        <td class="ps-4 py-3 text-center" style="width: 100px;">
                                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/80x80?text=No+Image" : item.ImageUrl)" alt="@item.ProductName" class="img-fluid rounded-3 mb-2" style="max-height: 60px;" />
                                            <br />
                                            <form asp-action="RemoveFromCart" method="post" class="d-inline">
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3" title="Xóa" onclick="return confirm('Bỏ sản phẩm này khỏi giỏ hàng?');"><i class="fa fa-trash-alt me-1"></i> Xóa</button>
                                            </form>
                                        </td>
                                        <td class="py-3">
                                            <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId" class="fw-bold text-dark text-decoration-none fs-5">@item.ProductName</a>
                                        </td>
                                        <td class="text-center fw-bold text-muted py-3">@item.Price.ToString("N0") đ</td>
                                        <td class="text-center py-3">
                                            <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center justify-content-center">
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <input type="number" name="quantity" value="@item.Quantity" min="1" max="10" class="form-control form-control-sm text-center fw-bold me-2" style="width: 60px;" onchange="this.form.submit()" />
                                            </form>
                                        </td>
                                        <td class="text-end fw-bolder text-danger pe-4 py-3 fs-5">@item.Total.ToString("N0") đ</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 rounded-4 border-top border-4" style="border-top-color: #f97316 !important;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold text-dark mb-4">Tóm tắt đơn hàng</h5>
                        
                        <div class="d-flex justify-content-between mb-3 text-muted">
                            <span>Tạm tính</span>
                            <span class="fw-bold text-dark">@totalCart.ToString("N0") đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4 text-muted border-bottom pb-3">
                            <span>Phí vận chuyển</span>
                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-2">Miễn phí</span>
                        </div>
                        
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fw-bold fs-5 text-dark">Tổng cộng</span>
                            <span class="fw-bolder fs-4 text-danger">@totalCart.ToString("N0") đ</span>
                        </div>

                        <a asp-action="Checkout" class="btn btn-lg w-100 rounded-pill fw-bold shadow-sm text-white" style="background: linear-gradient(135deg, #f97316, #fb923c); border: none;">
                            Tiến hành Thanh toán <i class="fa fa-arrow-right ms-2"></i>
                        </a>
                        <div class="text-center mt-3">
                            <a asp-controller="Home" asp-action="Shop" class="text-muted small text-decoration-none"><i class="fa fa-reply me-1"></i> Mua thêm sản phẩm khác</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>