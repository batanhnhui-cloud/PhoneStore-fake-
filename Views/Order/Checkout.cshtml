@model PhoneStore.Models.Order
@{
    ViewData["Title"] = "Thông tin giao hàng";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6 offset-md-3 shadow-lg p-4 rounded bg-white border border-primary">
            <h2 class="text-center text-primary mb-4 fw-bold">THÔNG TIN GIAO HÀNG</h2>
            <form asp-action="Checkout" method="post">
                <div class="form-group mb-3">
                    <label class="fw-bold mb-1">Họ và tên người nhận</label>
                    <input asp-for="CustomerName" class="form-control" placeholder="Ví dụ: Nguyễn Văn A" />
                    <span asp-validation-for="CustomerName" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label class="fw-bold mb-1">Số điện thoại liên hệ</label>
                    <input asp-for="Phone" class="form-control" placeholder="09xx xxx xxx" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label class="fw-bold mb-1">Địa chỉ nhận hàng chi tiết</label>
                    <textarea asp-for="Address" class="form-control" rows="3" placeholder="Số nhà, tên đường, phường..."></textarea>
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>
                <div class="alert alert-info">
                    Mọi đơn hàng đều được <strong>Miễn phí vận chuyển</strong> trong hôm nay!
                </div>
                <hr />
                <button type="submit" class="btn btn-danger btn-lg w-100 fw-bold py-3">XÁC NHẬN ĐẶT HÀNG NGAY</button>
            </form>
        </div>
    </div>
</div>