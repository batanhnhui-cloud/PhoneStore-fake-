<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Siêu thị PhoneStore</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="sticky-top shadow-sm bg-white" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);">
        <nav class="navbar navbar-expand-lg navbar-light py-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-dark fs-3 d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-2" style="width: 40px; height: 40px;">
                        <i class="fa fa-apple-alt"></i>
                    </div>
                    Phone<span class="text-primary">Store</span>
                </a>
                
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <i class="fa fa-bars fs-3"></i>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mx-4 mb-2 mb-lg-0 fw-semibold fs-5">
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="Home" asp-action="Index">Khám phá</a></li>
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="Product" asp-action="Index">Điện thoại</a></li>
                    </ul>

                    <ul class="navbar-nav align-items-center gap-2">
                        <li class="nav-item">
                            <a class="btn btn-light position-relative fw-bold text-dark px-3 py-2 border rounded-pill" asp-controller="Cart" asp-action="Index">
                                <i class="fa fa-shopping-bag me-1 text-primary"></i> Giỏ hàng
                            </a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                            {
                                <li class="nav-item">
                                    <a class="btn btn-dark rounded-pill px-4 fw-bold shadow-sm" asp-controller="Admin" asp-action="Dashboard">Vào Hệ thống</a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="btn btn-outline-dark rounded-pill px-4 fw-bold" asp-controller="Home" asp-action="MyOrders">Đơn của tôi</a>
                                </li>
                            }

                            <li class="nav-item dropdown ms-2">
                                <a class="nav-link dropdown-toggle fw-bold bg-light rounded-pill px-3 py-2" href="#" data-bs-toggle="dropdown">
                                    👋 @User.Identity.Name?.Split('@')[0]
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 mt-3">
                                    <li><form asp-controller="Account" asp-action="Logout" method="post" class="m-0 p-2"><button type="submit" class="dropdown-item text-danger fw-bold rounded-3"><i class="fa fa-sign-out-alt me-2"></i> Đăng xuất</button></form></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link fw-bold text-muted px-3" asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                            <li class="nav-item"><a class="btn btn-primary text-white rounded-pill px-4 fw-bold shadow-sm" asp-controller="Account" asp-action="Register">Đăng ký</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container main-content mt-4 mb-5" style="min-height: 65vh;">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-white border-top py-5 mt-auto">
        <div class="container text-center text-md-start">
            <div class="row align-items-center">
                <div class="col-md-6 mb-3 mb-md-0">
                    <h4 class="fw-bold text-dark mb-1">PhoneStore</h4>
                    <p class="text-muted small mb-0">Hệ thống phân phối điện thoại chính hãng hàng đầu.</p>
                </div>
                <div class="col-md-6 text-md-end text-muted small">
                    &copy; 2026 Bản quyền thuộc về bạn. Đồ án môn học xuất sắc.
                </div>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>