<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hệ thống PhoneStore</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
        /* Cấu hình khung giao diện cơ bản */
        body {
            background-color: #f8f9fa;
            display: flex;
            flex-direction: column;
            min-height: 100vh; /* Đẩy footer xuống đáy màn hình */
        }
        main {
            flex: 1;
        }
        .navbar-brand {
            font-weight: 800;
            letter-spacing: 1px;
        }
        .footer {
            background-color: #212529;
            color: #adb5bd;
            padding: 20px 0;
            margin-top: auto;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top py-3">
            <div class="container">
                <a class="navbar-brand text-primary fs-4" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fa fa-mobile-alt me-2"></i>PHONESTORE
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item ms-lg-4">
                            <a class="nav-link fw-bold text-dark hover-primary" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item ms-lg-2">
                            <a class="nav-link fw-bold text-dark hover-primary" asp-area="" asp-controller="Home" asp-action="Index">Điện thoại</a>
                        </li>
                        <li class="nav-item ms-lg-2">
                            <a class="nav-link fw-bold text-success" asp-area="" asp-controller="Cart" asp-action="Index">
                                <i class="fa fa-shopping-cart me-1"></i> Giỏ hàng
                            </a>
                        </li>
                    </ul>
                    
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="container mt-4 mb-5 pb-5">
        @RenderBody()
    </main>

    <footer class="footer text-center">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <p class="mb-0">&copy; @DateTime.Now.Year - <strong>Hệ thống Chuỗi Cửa hàng PhoneStore</strong></p>
                    <small>Đồ án xây dựng Website bán hàng ASP.NET Core MVC</small>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>