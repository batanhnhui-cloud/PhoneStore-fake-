<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Phone Store</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        .navbar-brand {
            font-size: 1.5rem;
            letter-spacing: 1px;
        }

        .nav-link {
            font-weight: 500;
            text-transform: uppercase;
            margin: 0 10px;
        }

        .cart-badge {
            position: absolute;
            top: -5px;
            right: -10px;
            padding: 2px 6px;
            border-radius: 50%;
            font-size: 10px;
        }
    </style>
</head>
<body>
    <header class="sticky-top shadow-sm">
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand fw-bold text-info" asp-controller="Home" asp-action="Index">📱 PHONE STORE</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link active" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">Khuyến mãi</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">Tin công nghệ</a></li>
                    </ul>
                    <div class="d-flex align-items-center">
                        <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-info position-relative me-3">
                            <i class="bi bi-cart3"></i> Giỏ hàng
                        </a>
                        <a asp-controller="Order" asp-action="AdminIndex" class="text-secondary text-decoration-none small">Admin</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="bg-dark text-white pt-5 pb-3 mt-5">
        <div class="container text-center">
            <p>&copy; 2026 - Cửa hàng điện thoại trực tuyến - Dự án ASP.NET Core MVC</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>