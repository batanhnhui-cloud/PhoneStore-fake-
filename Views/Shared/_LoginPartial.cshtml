@using Microsoft.AspNetCore.Identity
@using PhoneStore.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav ms-auto align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item me-3">
            @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
            {
                <a class="nav-link text-dark fw-bold" asp-controller="Staff" asp-action="Inventory">
                    <i class="fa fa-user-circle text-primary me-1"></i> @User.Identity?.Name
                </a>
            }
            else
            {
                <span class="nav-link text-dark fw-bold">
                    <i class="fa fa-user-circle text-secondary me-1"></i> @User.Identity?.Name
                </span>
            }
        </li>

        <li class="nav-item">
            <form class="form-inline m-0" asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="btn btn-danger btn-sm fw-bold shadow-sm">
                    <i class="fa fa-sign-out-alt me-1"></i> Đăng xuất
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item me-2">
            <a class="btn btn-outline-success px-4 fw-bold shadow-sm rounded-pill" asp-controller="Account" asp-action="Register">Đăng ký</a>
        </li>
        <li class="nav-item">
            <a class="btn btn-primary px-4 fw-bold shadow-sm rounded-pill" asp-controller="Account" asp-action="Login">Đăng nhập</a>
        </li>
    }
</ul>