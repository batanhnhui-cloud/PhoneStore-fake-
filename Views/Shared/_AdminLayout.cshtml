<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản trị PhoneStore</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        .sidebar { min-height: 100vh; background: #212529; color: white; width: 250px; }
        .sidebar .nav-link { color: #adb5bd; padding: 12px 20px; }
        .sidebar .nav-link:hover { background: #343a40; color: #fff; }
        .section-title { font-size: 0.7rem; text-transform: uppercase; color: #6c757d; padding: 15px 20px 5px; font-weight: bold; }
    </style>
</head>
<body>
    <div class="d-flex">
        <nav class="sidebar flex-column shadow">
            <div class="p-4 text-center border-bottom border-dark">
                <h4 class="fw-bold mb-0 text-white text-uppercase">PhoneStore</h4>
                <div class="badge bg-info text-dark mt-2">@(User.IsInRole("Admin") ? "Admin" : "Nhân viên")</div>
            </div>
            <ul class="nav flex-column mt-2">
                @if (User.IsInRole("Admin")) {
                    <div class="section-title">Hệ thống</div>
                    <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="RevenueReport"><i class="fa fa-chart-line me-2"></i>Doanh thu</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="ManageBranches"><i class="fa fa-store me-2"></i>Chi nhánh</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="ManageStaff"><i class="fa fa-users me-2"></i>Nhân sự</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Category" asp-action="Index"><i class="fa fa-tags me-2"></i>Hãng máy</a></li>
                }
                <div class="section-title">Cửa hàng</div>
                <li class="nav-item"><a class="nav-link" asp-controller="Product" asp-action="Index"><i class="fa fa-mobile-alt me-2"></i>Sản phẩm</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Staff" asp-action="Inventory"><i class="fa fa-warehouse me-2"></i>Kho hàng</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Staff" asp-action="OrderManagement"><i class="fa fa-shopping-cart me-2"></i>Đơn hàng</a></li>
                <div class="section-title">Hệ thống</div>
                <li class="nav-item">
                    <form asp-controller="Account" asp-action="Logout" method="post" class="p-0">
                        <button type="submit" class="nav-link border-0 bg-transparent text-danger w-100 text-start"><i class="fa fa-sign-out-alt me-2"></i>Đăng xuất</button>
                    </form>
                </li>
            </ul>
        </nav>
        <div class="flex-grow-1 bg-light">
            <header class="bg-white shadow-sm p-3 d-flex justify-content-between align-items-center">
                <span class="fw-bold">Xin chào, @User.Identity?.Name</span>
                <a href="/" class="btn btn-sm btn-outline-primary rounded-pill">Về trang chủ</a>
            </header>
            <div class="p-4">@RenderBody()</div>
        </div>
    </div>
</body>
</html>