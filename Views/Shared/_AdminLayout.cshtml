<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị PhoneStore</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        .sidebar { min-height: 100vh; background: #212529; color: white; width: 250px; }
        .sidebar .nav-link { color: #adb5bd; padding: 12px 20px; transition: all 0.3s; }
        .sidebar .nav-link:hover { background: #343a40; color: #fff; padding-left: 25px; }
        .section-title { font-size: 0.75rem; text-transform: uppercase; color: #6c757d; padding: 15px 20px 5px; font-weight: bold; letter-spacing: 1px; }
        .main-content { min-height: 100vh; background-color: #f4f6f9; }
    </style>
</head>
<body>
    <div class="d-flex">
        <nav class="sidebar flex-column shadow-lg">
            <div class="p-4 text-center border-bottom border-dark">
                <h4 class="fw-bold mb-0 text-white text-uppercase">
                    <i class="fa fa-mobile-screen-button me-2 text-primary"></i>PhoneStore
                </h4>
                <div class="badge bg-primary text-white mt-2 px-3 py-2 rounded-pill">
                    <i class="fa fa-user-circle me-1"></i> @(User.IsInRole("Admin") ? "Quản trị viên" : "Nhân viên")
                </div>
            </div>
            
            <ul class="nav flex-column mt-2">
                @if (User.IsInRole("Admin")) 
                {
                    <div class="section-title">Hệ thống (Vĩ mô)</div>
                    <li class="nav-item"><a class="nav-link text-info fw-bold" asp-controller="Admin" asp-action="Dashboard"><i class="fa fa-tachometer-alt me-2" style="width: 20px;"></i>Tổng quan</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="RevenueReport"><i class="fa fa-chart-line me-2" style="width: 20px;"></i>Chi tiết Doanh thu</a></li>
                    <li class="nav-item"><a class="nav-link text-warning fw-bold" asp-controller="Admin" asp-action="ManageCustomers"><i class="fa fa-users me-2" style="width: 20px;"></i>Khách hàng</a></li>
                    
                    <li class="nav-item"><a class="nav-link text-danger fw-bold" asp-controller="Admin" asp-action="OrderManagement"><i class="fa fa-shopping-cart me-2" style="width: 20px;"></i>Đơn hàng Toàn quốc</a></li>
                    
                    <li class="nav-item"><a class="nav-link fw-bold text-white" asp-controller="Admin" asp-action="ManageInventory"><i class="fa fa-boxes me-2" style="width: 20px;"></i>Tồn kho Toàn quốc</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="ManageBranches"><i class="fa fa-store me-2" style="width: 20px;"></i>Chi nhánh</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="ManageStaff"><i class="fa fa-user-tie me-2" style="width: 20px;"></i>Nhân sự</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Category" asp-action="Index"><i class="fa fa-tags me-2" style="width: 20px;"></i>Hãng máy</a></li>
                }
                
                <div class="section-title">Quản lý chung</div>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Product" asp-action="Index"><i class="fa fa-mobile-alt me-2" style="width: 20px;"></i>Danh mục Sản phẩm</a>
                </li>

                @if (User.IsInRole("Staff"))
                {
                    <div class="section-title">Nghiệp vụ Cửa hàng</div>
                    <li class="nav-item"><a class="nav-link text-success fw-bold" asp-controller="Staff" asp-action="POS"><i class="fa fa-cash-register me-2" style="width: 20px;"></i>Bán hàng (POS)</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Staff" asp-action="Inventory"><i class="fa fa-warehouse me-2" style="width: 20px;"></i>Kho hàng chi nhánh</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Staff" asp-action="OrderManagement"><i class="fa fa-shopping-cart me-2" style="width: 20px;"></i>Xử lý Đơn hàng</a></li>
                }
                
                <div class="section-title">Tài khoản</div>
                <li class="nav-item">
                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="p-0">
                        <button type="submit" class="nav-link border-0 bg-transparent text-danger w-100 text-start"><i class="fa fa-sign-out-alt me-2" style="width: 20px;"></i>Đăng xuất</button>
                    </form>
                </li>
            </ul>
        </nav>
        
        <div class="flex-grow-1 main-content">
            <header class="bg-white shadow-sm p-3 d-flex justify-content-between align-items-center sticky-top">
                <div class="fw-bold text-dark"><i class="fa fa-bars me-2 text-muted"></i>Xin chào, <span class="text-primary">@User.Identity?.Name</span></div>
                <div><a href="/" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-bold shadow-sm"><i class="fa fa-globe me-1"></i> Về trang chủ</a></div>
            </header>
            <div class="p-4">@RenderBody()</div>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>