@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị PhoneStore</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f8f9fa; }
        .sidebar { min-height: 100vh; background-color: #212529; color: white; padding-top: 20px; }
        .sidebar .nav-link { color: #adb5bd; transition: 0.3s; margin-bottom: 5px; }
        .sidebar .nav-link:hover { color: white; background-color: #343a40; border-radius: 5px; }
        .sidebar .nav-link.active { color: white; background-color: #0d6efd; border-radius: 5px; }
        .main-content { padding: 20px; }
        .top-navbar { background-color: white; border-bottom: 1px solid #dee2e6; padding: 10px 20px; }
    </style>
</head>
<body>

    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 d-md-block sidebar collapse">
                <div class="position-sticky">
                    <h4 class="text-center mb-4"><i class="fa fa-mobile-alt"></i> PhoneStore</h4>
                    <ul class="nav flex-column px-3">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fa fa-home me-2"></i> Trang chủ User
                            </a>
                        </li>
                        
                        <hr class="text-secondary" />
                        <h6 class="px-3 text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Quản trị hệ thống</h6>

                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Admin" asp-action="ManageStaff">
                                        <i class="fa fa-user-tie me-2"></i> Quản lý Nhân viên
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#">
                                        <i class="fa fa-users me-2"></i> Quản lý Khách hàng
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Staff" asp-action="OrderManagement">
                                        <i class="fa fa-shopping-cart me-2"></i> Quản lý Đơn hàng
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#">
                                        <i class="fa fa-box me-2"></i> Quản lý Sản phẩm
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </nav>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-0">
                <div class="top-navbar d-flex justify-content-between align-items-center">
                    <h5 class="m-0">Bảng điều khiển</h5>
                    <div class="user-info d-flex align-items-center">
                        <span class="me-3 text-muted">Xin chào, <strong>@User.Identity.Name</strong></span>
                        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Đăng xuất</button>
                        </form>
                    </div>
                </div>

                <div class="main-content">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>