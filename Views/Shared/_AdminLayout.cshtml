@using Microsoft.AspNetCore.Identity
@using PhoneStore.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hệ Thống Chuỗi PhoneStore</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
        :root { --sidebar-width: 260px; --topbar-height: 60px; --primary-color: #4e73df; }
        body { font-family: 'Inter', sans-serif; background-color: #f4f7fc; overflow-x: hidden; }
        
        /* Sidebar Styles */
        .sidebar { width: var(--sidebar-width); height: 100vh; position: fixed; left: 0; top: 0; background: #1a1c23; color: #9e9e9e; transition: all 0.3s; z-index: 1000; }
        .sidebar .brand { padding: 20px; color: white; border-bottom: 1px solid #2d2f39; text-align: center; }
        .sidebar .nav-link { color: #9e9e9e; padding: 12px 20px; display: flex; align-items: center; border-left: 4px solid transparent; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: white; background: #2d2f39; border-left-color: var(--primary-color); }
        .sidebar .nav-link i { width: 25px; font-size: 1.1rem; }
        .sidebar .section-title { font-size: 0.75rem; text-uppercase: uppercase; padding: 20px 20px 10px; color: #5c5e66; font-weight: bold; }

        /* Content Area */
        .main-wrapper { margin-left: var(--sidebar-width); min-height: 100vh; transition: all 0.3s; }
        .top-navbar { height: var(--topbar-height); background: white; border-bottom: 1px solid #e3e6f0; padding: 0 25px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 999; }
        .content-body { padding: 25px; }

        .branch-badge { background: #e8f0fe; color: #1967d2; padding: 4px 12px; border-radius: 20px; font-size: 0.85rem; font-weight: 500; }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="brand">
            <h4 class="m-0 fw-bold"><i class="fa fa-layer-group me-2"></i>PHONESTORE</h4>
            <small class="text-muted">Chain Management v2.0</small>
        </div>

        <nav class="mt-3">
            <a class="nav-link" asp-controller="Home" asp-action="Index">
                <i class="fa fa-tachometer-alt"></i> Tổng quan
            </a>

            @if (SignInManager.IsSignedIn(User))
            {
                @if (User.IsInRole("Admin"))
                {
                    <div class="section-title">Quản trị chuỗi</div>
                    <a class="nav-link" asp-controller="Admin" asp-action="ManageBranches">
                        <i class="fa fa-map-marker-alt"></i> Quản lý Chi nhánh
                    </a>
                    <a class="nav-link" asp-controller="Admin" asp-action="ManageStaff">
                        <i class="fa fa-user-shield"></i> Quản lý Nhân sự
                    </a>
                    <a class="nav-link" asp-controller="Category" asp-action="Index">
                        <i class="fa fa-tags"></i> Danh mục sản phẩm
                    </a>
                }

                <div class="section-title">Nghiệp vụ chi nhánh</div>
                <a class="nav-link" asp-controller="Staff" asp-action="MyBranchOrders">
                    <i class="fa fa-shopping-basket"></i> Đơn hàng tại kho
                </a>
                <a class="nav-link" asp-controller="Product" asp-action="Index">
                    <i class="fa fa-mobile-alt"></i> Quản lý Tồn kho
                </a>
                <a class="nav-link" href="#">
                    <i class="fa fa-history"></i> Báo cáo doanh thu
                </a>
            }
        </nav>
    </aside>

    <div class="main-wrapper">
        <header class="top-navbar">
            <div class="d-flex align-items-center">
                <span class="branch-badge">
                    <i class="fa fa-store me-1"></i> 
                    @(currentUser?.BranchId != null ? "Chi nhánh: ID " + currentUser.BranchId : "Toàn hệ thống")
                </span>
            </div>

            <div class="d-flex align-items-center">
                <div class="dropdown">
                    <a class="text-decoration-none text-dark dropdown-toggle fw-500" href="#" data-bs-toggle="dropdown">
                        <img src="https://ui-avatars.com/api/?name=@User.Identity.Name&background=random" class="rounded-circle me-2" width="32">
                        @User.Identity.Name
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                        <li><a class="dropdown-item" href="#"><i class="fa fa-user me-2"></i> Hồ sơ cá nhân</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                <button type="submit" class="dropdown-item text-danger border-0 bg-transparent w-100 text-start">
                                    <i class="fa fa-sign-out-alt me-2"></i> Đăng xuất
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <main class="content-body">
            @RenderBody()
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>