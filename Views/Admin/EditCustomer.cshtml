@model PhoneStore.Models.ApplicationUser
@{
    ViewData["Title"] = "Chỉnh sửa Khách hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary"><i class="fa fa-user-edit me-2"></i>Chỉnh sửa Khách hàng</h2>
</div>

<div class="card shadow border-0 p-4" style="max-width: 600px;">
    <form asp-action="EditCustomer" method="post">
        <input type="hidden" name="id" value="@Model.Id" />
        
        <div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

        <div class="mb-3">
            <label class="form-label fw-bold">Email (Tên đăng nhập)</label>
            <input class="form-control bg-light" value="@Model.Email" readonly disabled />
            <small class="text-muted">Email là định danh tài khoản, không thể thay đổi.</small>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Họ và Tên</label>
            <input name="fullName" class="form-control" value="@Model.FullName" required placeholder="Nhập họ tên khách hàng..." />
        </div>

        <div class="mb-4">
            <label class="form-label fw-bold">Số điện thoại</label>
            <input name="phoneNumber" class="form-control" value="@Model.PhoneNumber" placeholder="Cập nhật số điện thoại..." />
        </div>

        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-primary fw-bold py-2">
                <i class="fa fa-save me-1"></i> LƯU THAY ĐỔI
            </button>
            <a asp-action="ManageCustomers" class="btn btn-light text-muted">Hủy bỏ</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}