@model PhoneStore.Models.Branch
@{
    ViewData["Title"] = "Thêm Chi Nhánh Mới";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary"><i class="fa fa-plus-circle me-2"></i>Thêm Chi Nhánh Mới</h2>
    <a asp-action="ManageBranches" class="btn btn-outline-secondary">
        <i class="fa fa-arrow-left me-1"></i> Quay lại danh sách
    </a>
</div>

<div class="card shadow border-0" style="max-width: 600px;">
    <div class="card-header bg-white py-3">
        <h6 class="m-0 fw-bold text-success">Thông tin chi nhánh</h6>
    </div>
    <div class="card-body p-4">
        <form asp-action="CreateBranch" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold text-secondary">Tên Chi Nhánh <span class="text-danger">*</span></label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="fa fa-store text-muted"></i></span>
                    <input asp-for="Name" class="form-control" placeholder="VD: Chi nhánh Quận 1, Store Đà Nẵng..." required />
                </div>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Address" class="form-label fw-bold text-secondary">Địa chỉ chi tiết</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="fa fa-map-marker-alt text-muted"></i></span>
                    <textarea asp-for="Address" class="form-control" rows="3" placeholder="Số nhà, tên đường, phường, quận..."></textarea>
                </div>
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-success fw-bold px-4 py-2 w-100 fs-5 shadow-sm">
                <i class="fa fa-save me-2"></i> LƯU CHI NHÁNH
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}