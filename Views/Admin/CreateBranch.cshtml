@model PhoneStore.Models.Branch
@{
    ViewData["Title"] = "Thêm chi nhánh mới";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="text-success fw-bold mb-4"><i class="fa fa-plus-circle me-2"></i>Thêm chi nhánh mới</h2>

<div class="card shadow border-0 p-4" style="max-width: 500px;">
    <form asp-action="CreateBranch" method="post">
        <div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-bold">Tên chi nhánh</label>
            <input asp-for="Name" class="form-control" placeholder="VD: Chi nhánh Hà Nội..." required />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        
        <div class="mb-4">
            <label asp-for="Address" class="form-label fw-bold">Địa chỉ</label>
            <input asp-for="Address" class="form-control" placeholder="Nhập địa chỉ đầy đủ..." required />
            <span asp-validation-for="Address" class="text-danger small"></span>
        </div>
        
        <button type="submit" class="btn btn-success w-100 fw-bold py-2"><i class="fa fa-save me-1"></i> THÊM CHI NHÁNH</button>
        <a asp-action="ManageBranches" class="btn btn-light w-100 mt-2 text-muted">Quay lại</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}