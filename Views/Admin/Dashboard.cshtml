@model IEnumerable<PhoneStore.Models.Order>
@{
    ViewData["Title"] = "Dashboard Tổng Quan";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4 mb-5">
    <h2 class="fw-bolder text-dark mb-4"><i class="fa fa-chart-line text-primary me-2"></i>Tổng Quan Hệ Thống</h2>

    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-0 border-start border-primary border-5 shadow-sm h-100 py-2">
                <div class="card-body">
                    <div class="text-xs fw-bold text-primary text-uppercase mb-1">Doanh thu (Thành công)</div>
                    <div class="h4 mb-0 fw-bold text-dark">@(ViewBag.TotalRevenue?.ToString("N0") ?? "0") đ</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-0 border-start border-success border-5 shadow-sm h-100 py-2">
                <div class="card-body">
                    <div class="text-xs fw-bold text-success text-uppercase mb-1">Tổng thiết bị sẵn bán</div>
                    <div class="h4 mb-0 fw-bold text-dark">@ViewBag.TotalDevices máy</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-0 border-start border-info border-5 shadow-sm h-100 py-2">
                <div class="card-body">
                    <div class="text-xs fw-bold text-info text-uppercase mb-1">Tổng Đơn Hàng</div>
                    <div class="h4 mb-0 fw-bold text-dark">@ViewBag.TotalOrders đơn</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-0 border-start border-warning border-5 shadow-sm h-100 py-2">
                <div class="card-body">
                    <div class="text-xs fw-bold text-warning text-uppercase mb-1">Chi nhánh hoạt động</div>
                    <div class="h4 mb-0 fw-bold text-dark">@ViewBag.TotalBranches</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-white border-bottom py-3">
            <h6 class="m-0 fw-bold text-dark"><i class="fa fa-clock text-muted me-2"></i>5 Giao dịch gần nhất</h6>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Chi nhánh</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-primary">@item.CustomerName</td>
                            <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.Branch?.Name</td>
                            <td class="fw-bold text-danger">@item.TotalAmount.ToString("N0") đ</td>
                            <td>
                                @{
                                    var badge = item.Status switch { "Pending" => "bg-warning text-dark", "Success" => "bg-success", _ => "bg-danger" };
                                    var text = item.Status switch { "Pending" => "Chờ duyệt", "Success" => "Thành công", _ => "Đã hủy" };
                                }
                                <span class="badge @badge rounded-pill">@text</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>