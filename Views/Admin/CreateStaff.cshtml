@model PhoneStore.Models.ApplicationUser
@{
    ViewData["Title"] = "Thêm Nhân Viên Chi Nhánh";
}

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Tạo tài khoản Nhân viên mới</h6>
    </div>
    <div class="card-body">
        <form asp-action="CreateStaff" method="post">
            <div class="mb-3">
                <label class="form-label">Họ tên nhân viên</label>
                <input name="fullName" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Email đăng nhập</label>
                <input name="email" type="email" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Mật khẩu</label>
                <input name="password" type="password" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Gán vào Chi nhánh</label>
                <select name="branchId" class="form-select" asp-items="ViewBag.Branches">
                    <option value="">-- Chọn chi nhánh làm việc --</option>
                </select>
            </div>
            <button type="submit" class="btn btn-success">Xác nhận tạo</button>
            <a asp-action="ManageStaff" class="btn btn-secondary">Hủy</a>
        </form>
    </div>
</div>