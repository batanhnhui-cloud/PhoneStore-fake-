@model PhoneStore.Models.Branch
@{
    ViewData["Title"] = "Sửa chi nhánh";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="text-primary fw-bold mb-4">Chỉnh sửa chi nhánh</h2>

<div class="card shadow border-0 p-4" style="max-width: 500px;">
    <form asp-action="EditBranch" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label class="form-label fw-bold">Tên chi nhánh</label>
            <input asp-for="Name" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Địa chỉ</label>
            <input asp-for="Address" class="form-control" required />
        </div>
        <button type="submit" class="btn btn-primary w-100">LƯU THAY ĐỔI</button>
        <a asp-action="ManageBranches" class="btn btn-link w-100 mt-2">Quay lại</a>
    </form>
</div>

@* Phần này gây ra lỗi nếu Layout không có RenderSection *@
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}