@model PhoneStore.Models.ApplicationUser
@{
    ViewData["Title"] = "Sửa nhân viên";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="fw-bold text-primary mb-4"><i class="fa fa-user-edit me-2"></i>Chỉnh sửa nhân viên</h2>

<div class="card shadow border-0 p-4" style="max-width: 600px;">
    <form asp-action="EditStaff" method="post">
        <input type="hidden" name="id" value="@Model.Id" />
        
        <div class="row">
            <div class="col-md-12 mb-3">
                <label class="form-label fw-bold">Họ và Tên</label>
                <input name="fullName" class="form-control" value="@Model.FullName" required />
            </div>

            <div class="col-md-12 mb-3">
                <label class="form-label fw-bold">Email (Tên đăng nhập)</label>
                <input name="email" type="email" class="form-control" value="@Model.Email" required />
            </div>

            <div class="col-md-12 mb-3">
                <label class="form-label fw-bold text-danger">Mật khẩu mới (Tùy chọn)</label>
                <input name="newPassword" type="password" class="form-control" placeholder="Để trống nếu không muốn thay đổi" />
                <small class="text-muted">Chỉ nhập nếu bạn muốn cấp lại mật khẩu cho nhân viên này.</small>
            </div>

            <div class="col-md-12 mb-4">
                <label class="form-label fw-bold">Chi nhánh công tác</label>
                <select name="branchId" class="form-select" asp-items="ViewBag.Branches" required>
                    <option value="">-- Chọn chi nhánh --</option>
                </select>
            </div>
        </div>

        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-primary fw-bold py-2">
                <i class="fa fa-save me-1"></i> CẬP NHẬT THÔNG TIN
            </button>
            <a asp-action="ManageStaff" class="btn btn-light text-muted">Hủy bỏ</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}