@@model IEnumerable<PhoneStore.Models.ApplicationUser>
@{
    ViewData["Title"] = "Quản lý Nhân sự";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary"><i class="fa fa-users-cog me-2"></i>Quản lý Nhân viên</h2>
    <a asp-action="CreateStaff" class="btn btn-success fw-bold shadow-sm">
        <i class="fa fa-user-plus me-1"></i> THÊM NHÂN VIÊN
    </a>
</div>

<div class="card shadow border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Họ và Tên</th>
                    <th>Email Tài khoản</th>
                    <th>Chi nhánh trực thuộc</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@user.FullName</td>
                        <td>@user.Email</td>
                        <td>
                            <span class="badge bg-info text-dark">
                                <i class="fa fa-store me-1"></i>@(user.Branch?.Name ?? "Chưa gán")
                            </span>
                        </td>
                        <td class="text-center">
                            <a asp-action="EditStaff" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary me-2">
                                <i class="fa fa-edit"></i> Sửa
                            </a>
                            <a asp-action="DeleteStaff" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Xóa tài khoản này?')">
                                <i class="fa fa-trash"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>