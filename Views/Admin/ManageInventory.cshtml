@model IEnumerable<PhoneStore.Controllers.InventoryStatVM>
@{
    ViewData["Title"] = "Quản lý Kho Tổng Hệ Thống";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h2 class="fw-bolder text-dark mb-0"><i class="fa fa-warehouse text-success me-2"></i>Giám Sát Kho Tổng Toàn Hệ Thống</h2>
        <div class="badge bg-success bg-opacity-10 text-success px-4 py-2 fs-6 rounded-pill border border-success border-opacity-25 shadow-sm">
            Tổng tài sản: <span class="fw-bolder">@Model.Sum(m => m.AvailableCount) máy</span>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-dark"><i class="fa fa-list me-2 text-info"></i>Phân bổ thiết bị theo Chi nhánh</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">CHI NHÁNH SỞ HỮU</th>
                        <th>DÒNG ĐIỆN THOẠI</th>
                        <th class="text-center">SỐ LƯỢNG TỒN</th>
                        <th class="text-center">ĐÁNH GIÁ MỨC TỒN</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="4" class="text-center py-5 fw-bold text-danger">Toàn bộ hệ thống đang hết hàng.</td></tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark"><i class="fa fa-store text-muted me-2"></i>@item.BranchName</td>
                                <td class="text-primary fw-semibold">@item.ProductName</td>
                                <td class="text-center fs-5 fw-bolder">@item.AvailableCount</td>
                                <td class="text-center">
                                    @if (item.AvailableCount <= 3)
                                    {
                                        <span class="badge bg-danger rounded-pill px-3 py-2 shadow-sm"><i class="fa fa-exclamation-circle me-1"></i>Sắp hết hàng</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success rounded-pill px-3 py-2 shadow-sm"><i class="fa fa-check me-1"></i>An toàn</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>