@model IEnumerable<PhoneStore.Models.Inventory>
@{
    ViewData["Title"] = "Quản lý Tồn kho Toàn quốc";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary"><i class="fa fa-boxes me-2"></i>Tồn kho Toàn hệ thống</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success fw-bold shadow-sm alert-dismissible fade show" role="alert">
        <i class="fa fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow border-0 mb-4 bg-light">
    <div class="card-body">
        <form asp-action="ManageInventory" method="get" class="row align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-bold text-muted">Lọc theo chi nhánh</label>
                <select name="branchId" class="form-select border-primary" asp-items="ViewBag.Branches" onchange="this.form.submit()">
                    <option value="">-- Hiển thị Tất cả chi nhánh --</option>
                </select>
            </div>
            <div class="col-md-7 text-end">
                <span class="badge bg-primary fs-6 py-2 px-3">
                    Đang hiển thị: @Model.Count() bản ghi tồn kho
                </span>
            </div>
        </form>
    </div>
</div>

<div class="card shadow border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Chi nhánh</th>
                        <th>Sản phẩm</th>
                        <th class="text-center" style="width: 250px;">Số lượng kho</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">Không có dữ liệu tồn kho.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="fw-bold text-dark"><i class="fa fa-store text-muted me-2"></i>@item.Branch?.Name</span>
                                </td>
                                <td>
                                    <div class="fw-bold text-primary">@item.Product?.Name</div>
                                    <small class="text-muted">Mã SP: #@item.ProductId</small>
                                </td>
                                <td class="text-center pe-4">
                                    <form asp-action="UpdateStock" method="post" class="d-inline-flex">
                                        <input type="hidden" name="inventoryId" value="@item.Id" />
                                        <input type="hidden" name="filterBranchId" value="@ViewBag.CurrentBranchId" />
                                        
                                        <div class="input-group input-group-sm">
                                            <input type="number" name="newQuantity" class="form-control text-center fw-bold" value="@item.StockQuantity" min="0" style="width: 70px;">
                                            <button type="submit" class="btn btn-outline-success fw-bold">Lưu</button>
                                        </div>
                                    </form>
                                    @if (item.StockQuantity <= 5)
                                    {
                                        <div class="text-danger small fw-bold mt-1"><i class="fa fa-exclamation-triangle me-1"></i>Sắp hết hàng</div>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>