@model IEnumerable<PhoneStore.Models.Category>
@{
    ViewData["Title"] = "Quản lý Hãng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary"><i class="fa fa-tags me-2"></i>Hãng Điện Thoại</h2>
    <a asp-action="Create" class="btn btn-success"><i class="fa fa-plus me-1"></i> Thêm hãng mới</a>
</div>

<div class="card shadow border-0" style="max-width: 700px;">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">ID</th>
                    <th>Tên Hãng</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">@item.Id</td>
                        <td class="fw-bold">@item.Name</td>
                        <td class="text-end pe-4">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info"><i class="fa fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger ms-1" onclick="return confirm('Xóa hãng sẽ xóa các sản phẩm thuộc hãng này. Chắc chắn không?')"><i class="fa fa-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>