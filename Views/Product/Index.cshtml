@model IEnumerable<PhoneStore.Models.Product>
@{
    ViewData["Title"] = "Quản lý Sản phẩm";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary"><i class="fa fa-mobile-alt me-2"></i>Danh sách Sản phẩm</h2>
    <a asp-action="Create" class="btn btn-success shadow-sm"><i class="fa fa-plus me-1"></i> Thêm máy mới</a>
</div>

<div class="card shadow border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Ảnh</th>
                    <th>Tên Máy</th>
                    <th>Hãng</th>
                    <th>Giá Bán</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4"><img src="@item.ImageUrl" style="width: 50px; height: 50px; object-fit: contain;" onerror="this.src='https://placehold.co/50x50?text=SP'" /></td>
                        <td class="fw-bold">@item.Name</td>
                        <td><span class="badge bg-info text-dark">@item.Category?.Name</span></td>
                        <td class="text-danger fw-bold">@item.Price.ToString("N0") đ</td>
                        <td class="text-end pe-4">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info"><i class="fa fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger ms-1" onclick="return confirm('Bạn có chắc chắn muốn xóa máy này?')"><i class="fa fa-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>