@model PhoneStore.Models.Product
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<h2 class="fw-bold text-primary mb-4">Sửa thông tin Điện thoại</h2>
<div class="card shadow border-0 p-4" style="max-width: 600px;">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label class="form-label fw-bold">Tên sản phẩm</label>
            <input asp-for="Name" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Hãng</label>
            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories"></select>
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Giá bán</label>
            <input asp-for="Price" type="number" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Link ảnh</label>
            <input asp-for="ImageUrl" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary fw-bold w-100 py-2">LƯU THAY ĐỔI</button>
        <a asp-action="Index" class="btn btn-link w-100 mt-2">Hủy bỏ</a>
    </form>
</div>