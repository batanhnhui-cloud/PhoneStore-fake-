@using System.Text.Json
@model PhoneStore.Models.Product
@{
    ViewData["Title"] = Model.Name + " - SunMobile";

    // Logic xử lý JSON Cấu hình
    Dictionary<string, List<string>> specDictionary = new Dictionary<string, List<string>>();
    if (!string.IsNullOrEmpty(Model.Specifications))
    {
        try {
            using (JsonDocument doc = JsonDocument.Parse(Model.Specifications)) {
                foreach (var element in doc.RootElement.EnumerateObject()) {
                    var list = new List<string>();
                    if (element.Value.ValueKind == JsonValueKind.Array)
                        foreach (var item in element.Value.EnumerateArray()) list.Add(item.GetString());
                    else if (element.Value.ValueKind == JsonValueKind.String)
                        list.Add(element.Value.GetString());
                    specDictionary.Add(element.Name, list);
                }
            }
        } catch { }
    }
}

<style>
    :root {
        --sun-orange: #f97316;
        --sun-orange-light: #fb923c;
        --sun-dark: #1e293b;
    }

    body { background-color: #f8fafc; font-family: 'Inter', sans-serif; }

    .details-card { background: #fff; border-radius: 30px; border: none; overflow: hidden; }
    
    .img-main-wrapper { background: #fff; border-radius: 24px; padding: 30px; transition: transform 0.3s; }
    .img-main-wrapper:hover { transform: scale(1.02); }
    .img-main { width: 100%; max-height: 500px; object-fit: contain; }

    .brand-badge { background: rgba(249, 115, 22, 0.1); color: var(--sun-orange); font-weight: 800; text-transform: uppercase; letter-spacing: 1px; padding: 8px 16px; border-radius: 50px; display: inline-block; font-size: 0.75rem; }

    .price-tag { color: #ef4444; font-size: 2.5rem; font-weight: 800; letter-spacing: -1px; }

    .btn-add-cart { background: linear-gradient(135deg, var(--sun-orange), var(--sun-orange-light)); color: white; border: none; border-radius: 50px; padding: 18px; font-weight: 700; font-size: 1.1rem; transition: all 0.3s; }
    .btn-add-cart:hover { transform: translateY(-3px); box-shadow: 0 10px 25px rgba(249, 115, 22, 0.3); color: white; }

    .spec-table-card { border-radius: 20px; border: 1px solid #f1f5f9; }
    .spec-row { display: flex; padding: 15px 20px; border-bottom: 1px solid #f1f5f9; }
    .spec-row:last-child { border-bottom: none; }
    .spec-label { flex: 0 0 35%; color: #64748b; font-weight: 500; font-size: 0.9rem; }
    .spec-value { flex: 1; color: var(--sun-dark); font-weight: 600; font-size: 0.95rem; white-space: pre-line; }

    .policy-box { background: #f1f5f9; border-radius: 15px; padding: 15px; }
</style>

<div class="container my-5">
    <nav class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-muted text-decoration-none">Cửa hàng</a></li>
            <li class="breadcrumb-item active fw-bold text-dark">@Model.Name</li>
        </ol>
    </nav>

    <div class="row g-5">
        <div class="col-lg-6">
            <div class="img-main-wrapper shadow-sm">
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://via.placeholder.com/600x600" : Model.ImageUrl)" class="img-main" alt="@Model.Name">
            </div>
        </div>

        <div class="col-lg-6">
            <div class="ps-lg-4">
                <div class="brand-badge mb-3">@Model.Category?.Name</div>
                <h1 class="display-5 fw-bolder text-dark mb-3">@Model.Name</h1>
                
                <div class="price-tag mb-4">
                    @Model.Price.ToString("N0") <span class="fs-4 fw-normal">đ</span>
                </div>

                <div class="policy-box d-flex justify-content-around mb-4 text-center">
                    <div><i class="fa fa-truck text-orange mb-1"></i><div class="small fw-bold">Ship hỏa tốc</div></div>
                    <div><i class="fa fa-shield-check text-orange mb-1"></i><div class="small fw-bold">Bảo hành 12th</div></div>
                    <div><i class="fa fa-rotate text-orange mb-1"></i><div class="small fw-bold">Lỗi là đổi</div></div>
                </div>

                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="mb-5">
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <button type="submit" class="btn-add-cart w-100 shadow">
                        <i class="fa fa-cart-shopping me-2"></i> CHO VÀO GIỎ HÀNG - MUA NGAY
                    </button>
                </form>

                <div class="spec-table-card bg-white shadow-sm overflow-hidden">
                    <div class="p-3 bg-light border-bottom fw-bold text-dark">
                        <i class="fa fa-microchip me-2 text-orange"></i>Thông số kỹ thuật
                    </div>
                    @if (specDictionary.Count > 0)
                    {
                        @foreach (var spec in specDictionary)
                        {
                            <div class="spec-row">
                                <div class="spec-label">@spec.Key</div>
                                <div class="spec-value">
                                    @foreach (var val in spec.Value)
                                    {
                                        <div class="mb-1">@val</div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted small">Thông số đang được cập nhật...</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>