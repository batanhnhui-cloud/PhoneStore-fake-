@model PhoneStore.Models.Product
@{
    ViewData["Title"] = Model.Name;
}

<div class="container my-5">
    <a asp-controller="Home" asp-action="Shop" class="btn btn-light rounded-pill px-4 fw-bold shadow-sm mb-4 border">
        <i class="fa fa-arrow-left me-2"></i> Quay lại cửa hàng
    </a>

    <div class="card shadow-lg border-0 rounded-5 overflow-hidden bg-white">
        <div class="row g-0">
            <div class="col-md-5 p-5 d-flex align-items-center justify-content-center bg-light border-end">
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://via.placeholder.com/500x500?text=No+Image" : Model.ImageUrl)"
                     class="img-fluid object-fit-contain drop-shadow"
                     style="max-height: 450px; transition: transform 0.3s;"
                     onmouseover="this.style.transform='scale(1.05)'"
                     onmouseout="this.style.transform='scale(1)'"
                     alt="@Model.Name">
            </div>

            <div class="col-md-7 p-5">
                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill fw-bold mb-3"><i class="fa fa-star me-1 text-danger"></i> Sản phẩm Chính hãng</span>
                <h2 class="display-6 fw-bolder text-dark mb-3">@Model.Name</h2>
                
                <h3 class="text-danger fw-bolder mb-4">@Model.Price.ToString("N0") <small class="text-muted text-decoration-line-through fs-5 ms-2">@((Model.Price * 1.1m).ToString("N0")) đ</small></h3>

                <div class="bg-light rounded-4 p-4 border mb-4">
                    <h6 class="fw-bold mb-3 text-dark"><i class="fa fa-award me-2" style="color: #f97316;"></i>ĐẶC QUYỀN TẠI SUNMOBILE</h6>
                    <ul class="list-unstyled mb-0 small text-muted lh-lg">
                        <li><i class="fa fa-check-circle text-success me-2"></i>Bảo hành 12 tháng điện tử qua mã IMEI</li>
                        <li><i class="fa fa-check-circle text-success me-2"></i>Hỗ trợ 1 đổi 1 trong vòng 30 ngày</li>
                        <li><i class="fa fa-check-circle text-success me-2"></i>Giao hàng hỏa tốc nội thành 2 giờ</li>
                    </ul>
                </div>

                <div class="mb-5">
                    <h6 class="fw-bold text-dark mb-2">Mô tả sản phẩm:</h6>
                    <p class="text-muted" style="line-height: 1.8;">Sản phẩm chính hãng nguyên seal. Hỗ trợ đầy đủ các tính năng hiện đại nhất. Hệ thống lưu trữ bảo hành thông minh bằng mã IMEI chống giả mạo. Chi tiết cấu hình vui lòng xem trên vỏ hộp hoặc liên hệ nhân viên tư vấn.</p>
                </div>

                <hr class="mb-4" />

                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-flex align-items-center gap-3">
                    <input type="hidden" name="productId" value="@Model.Id" />
                    
                    <div class="input-group" style="width: 130px;">
                        <span class="input-group-text bg-white fw-bold">SL</span>
                        <input type="number" name="quantity" value="1" min="1" max="10" class="form-control text-center fw-bold text-primary bg-light" required />
                    </div>

                    <button type="submit" class="btn btn-lg w-100 rounded-pill fw-bold shadow-sm" style="background: linear-gradient(135deg, #f97316, #fb923c); color: white; border: none;">
                        <i class="fa fa-shopping-cart me-2"></i> THÊM VÀO GIỎ HÀNG
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>