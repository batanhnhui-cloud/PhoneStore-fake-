@model IEnumerable<PhoneStore.Models.Product>
@{
    ViewData["Title"] = "Quản lý Sản phẩm";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary"><i class="fa fa-mobile-alt me-2"></i>Danh mục Sản phẩm</h2>
    <a asp-action="Create" class="btn btn-success"><i class="fa fa-plus me-1"></i> Thêm sản phẩm</a>
</div>

<div class="row row-cols-1 row-cols-md-4 g-4">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm border-0">
                <img src="@item.ImageUrl" class="card-img-top p-3" style="height: 200px; object-fit: contain;" alt="@item.Name" onerror="this.src='https://placehold.co/200x200?text=No+Image'">
                <div class="card-body border-top">
                    <h5 class="card-title fw-bold text-truncate" title="@item.Name">@item.Name</h5>
                    <p class="text-danger fw-bold fs-5 mb-1">@item.Price.ToString("N0") đ</p>
                    <p class="text-muted small mb-3">@item.Category?.Name</p>
                    
                    <div class="d-flex justify-content-between">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary w-50 me-1">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger w-50 ms-1">Xóa</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>