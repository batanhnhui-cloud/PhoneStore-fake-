@model IEnumerable<PhoneStore.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="container mt-5">
    <h2 class="fw-bold mb-4 text-primary">Đơn hàng của bạn</h2>
    <div class="card shadow-sm border-0">
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <p class="text-muted">Bạn chưa có đơn hàng nào.</p>
                    <a href="/" class="btn btn-primary">Mua sắm ngay</a>
                </div>
            }
            else
            {
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Mã đơn</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>#@item.Id</td>
                                <td>@item.OrderDate.ToString("dd/MM/yyyy")</td>
                                <td class="fw-bold">@item.TotalAmount.ToString("N0") đ</td>
                                <td>
                                    <span class="badge @(item.Status == "Success" ? "bg-success" : "bg-warning")">@item.Status</span>
                                </td>
                                <td>
                                    <a asp-action="OrderDetails" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>