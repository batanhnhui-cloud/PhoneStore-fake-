@model IEnumerable<PhoneStore.Models.Category>

@{
    Layout = "_AdminLayout";
}

@{
    ViewData["Title"] = "Quản lý Hãng";
}

<div class="container mt-4">
    <h2>DANH SÁCH CÁC HÃNG ĐIỆN THOẠI</h2>
    <p>
        <a asp-action="Create" class="btn btn-success">Thêm hãng mới</a>
    </p>
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Mã Hãng</th>
                <th>Tên Hãng</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>
                        <a href="#" class="btn btn-sm btn-warning">Sửa</a>
                        <a href="#" class="btn btn-sm btn-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>